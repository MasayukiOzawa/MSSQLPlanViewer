@inject IJSRuntime JS

@if (Layout is null || Layout.Nodes.Count == 0)
{
    <p class="empty-state">There are no operators to display.</p>
}
else
{
    <div class="graph-toolbar">
        <div class="graph-toolbar-copy">
            <span class="graph-toolbar-label">Zoom</span>
            <strong>@ZoomLabel</strong>
        </div>
        <div class="graph-zoom-controls">
            <button class="btn btn-outline-secondary btn-sm" @onclick="ZoomOut" disabled="@(!CanZoomOut)">-</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ResetZoom">Reset</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ZoomIn" disabled="@(!CanZoomIn)">+</button>
        </div>
        <div class="graph-export-controls">
            <button class="btn btn-outline-secondary btn-sm" @onclick="ExportSvg">Export SVG</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ExportPng">Export PNG</button>
            @if (!string.IsNullOrEmpty(exportError))
            {
                <span class="graph-export-error" role="alert">@exportError</span>
            }
        </div>
    </div>

    <div class="graph-resize-frame">
        <div class="graph-shell" @ref="graphShellRef">
            <svg @ref="svgRef"
                 class="graph-canvas"
                 viewBox="@($"0 0 {Layout.Width} {Layout.Height}")"
                 preserveAspectRatio="xMinYMin meet"
                 width="@ScaledWidth"
                 height="@ScaledHeight"
                 role="img"
                 aria-label="Execution plan graph">
            <defs>
                <marker id="@MarkerId" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="userSpaceOnUse">
                    <path d="M 0 0 L 8 4 L 0 8 z" fill="#94a3b8" />
                </marker>
                <marker id="@EstimatedMarkerId" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="userSpaceOnUse">
                    <path d="M 0 0 L 8 4 L 0 8 z" fill="#94a3b8" />
                </marker>
                <marker id="@ActualMarkerId" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto" markerUnits="userSpaceOnUse">
                    <path d="M 0 0 L 8 4 L 0 8 z" fill="#0f766e" />
                </marker>
            </defs>

            @foreach (var edge in Layout.StatementEdges)
            {
                <path d="@BuildEdgePath(edge, Layout.Direction)"
                      class="graph-edge statement-edge"
                      marker-end="@($"url(#{MarkerId})")" />
            }

            @if (ShowCriticalPath)
            {
                @foreach (var edge in Layout.Edges.Where(edge => edge.IsOnCriticalPath))
                {
                    <path d="@BuildEdgePath(edge, Layout.Direction)"
                          class="graph-edge critical-path-outline"
                          style="@BuildCriticalEdgeOutlineStyle(edge)" />
                }
            }

            @foreach (var edge in Layout.Edges)
            {
                <path d="@BuildEdgePath(edge, Layout.Direction)"
                      class="graph-edge"
                      style="@BuildEdgeStrokeStyle(edge)"
                      marker-end="@($"url(#{ResolveEdgeMarkerId(edge)})")" />
            }

            @foreach (var edge in Layout.Edges)
            {
                var edgeFlowLabel = BuildEdgeFlowLabel(edge, Layout.Direction);
                @if (edgeFlowLabel is not null)
                {
                    <g class="edge-flow-label" aria-hidden="true">
                        <rect x="@(edgeFlowLabel.X - (edgeFlowLabel.Width / 2d))"
                              y="@(edgeFlowLabel.Y - 26d)"
                              width="@edgeFlowLabel.Width"
                              height="@edgeFlowLabel.Height"
                              rx="6"
                              ry="6"
                              class="edge-flow-label-bg" />
                        <text x="@edgeFlowLabel.LabelX" y="@(edgeFlowLabel.Y - 8d)" class="edge-flow-label-text edge-flow-label-name">@edgeFlowLabel.EstimatedRowsName</text>
                        <text x="@edgeFlowLabel.ValueX" y="@(edgeFlowLabel.Y - 8d)" class="edge-flow-label-text edge-flow-label-value">@edgeFlowLabel.EstimatedRowsValue</text>
                        <text x="@edgeFlowLabel.LabelX" y="@(edgeFlowLabel.Y + 11d)" class="edge-flow-label-text edge-flow-label-name">@edgeFlowLabel.ActualRowsName</text>
                        <text x="@edgeFlowLabel.ValueX" y="@(edgeFlowLabel.Y + 11d)" class="edge-flow-label-text edge-flow-label-value">@edgeFlowLabel.ActualRowsValue</text>
                    </g>
                }
            }

            @if (Layout.StatementNode is not null)
            {
                var statementNode = Layout.StatementNode;
                var isStatementSelected = string.Equals(statementNode.StatementId, SelectedStatementId, StringComparison.Ordinal);
                var bodyX = statementNode.X;
                var bodyY = statementNode.Y;
                var iconTileX = bodyX + 16;
                var iconTileY = bodyY + 16;
                var iconOriginX = iconTileX + 8;
                var iconOriginY = iconTileY + 8;
                var contentX = bodyX + 66;
                var contentY = bodyY + 28;

                <g class="@GetStatementNodeClass(isStatementSelected)"
                   data-statement-id="@statementNode.StatementId"
                   @onclick="@(() => SelectStatement(statementNode.StatementId))">
                    <rect x="@bodyX" y="@bodyY" width="@statementNode.Width" height="@statementNode.Height" rx="18" ry="18" class="statement-node-body" />
                    <rect x="@iconTileX" y="@iconTileY" width="34" height="34" rx="10" ry="10" class="statement-node-icon-tile" />
                    <g class="statement-node-icon" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                        <rect x="@iconOriginX" y="@iconOriginY" width="20" height="20" rx="3"></rect>
                        <line x1="@(iconOriginX + 5)" y1="@(iconOriginY + 6)" x2="@(iconOriginX + 15)" y2="@(iconOriginY + 6)"></line>
                        <line x1="@(iconOriginX + 5)" y1="@(iconOriginY + 10)" x2="@(iconOriginX + 15)" y2="@(iconOriginY + 10)"></line>
                        <line x1="@(iconOriginX + 5)" y1="@(iconOriginY + 14)" x2="@(iconOriginX + 12)" y2="@(iconOriginY + 14)"></line>
                    </g>
                    <text x="@contentX" y="@contentY" class="graph-title">
                        @Trim(statementNode.PrimaryLabel, 30)
                    </text>
                </g>
            }

            @foreach (var node in Layout.Nodes)
            {
                var isSelected = string.Equals(node.NodeId, SelectedNodeId, StringComparison.Ordinal);
                var icon = OperatorIconRegistry.Resolve(node.PhysicalOp, node.LogicalOp);
                var isScan = IsScanOperator(node, icon);
                var bodyX = node.X;
                var bodyY = node.Y;
                var iconTileX = bodyX + 16;
                var iconTileY = bodyY + 40;
                var iconOriginX = iconTileX + 8;
                var iconOriginY = iconTileY + 8;
                var parallelBadgeX = iconTileX + 3.5d;
                var parallelBadgeY = iconTileY + 40d;
                var implicitConversionBadgeX = iconTileX + 3.5d;
                var implicitConversionBadgeY = iconTileY + (node.IsParallel ? 70d : 40d);
                var isCriticalNode = ShowCriticalPath && node.IsOnCriticalPath;
                var costEmphasisLevel = ResolveCostEmphasisLevel(node);
                var costEmphasisStyle = GraphCostEmphasis.GetStyle(costEmphasisLevel);
                var isCostEmphasized = GraphCostEmphasis.IsEmphasized(costEmphasisLevel);
                var hasDashedOutline = isCostEmphasized;
                var contentX = bodyX + 66;
                var metricValueX = bodyX + node.Width - 24;
                var nodeIdLabel = $"Node {node.NodeId}";
                var nodeIdTextX = bodyX + (node.Width / 2d);
                var nodeIdTextY = bodyY + 17d;
                var headerBandHeight = 24d;
                var accentY = bodyY + headerBandHeight;
                var contentY = bodyY + 47;
                var meterRatio = (double)Math.Max(0.08m, node.CostRatio);
                var meterWidth = Math.Max(18d, (node.Width - 32) * meterRatio);
                var meterHeight = isCostEmphasized ? 7d : 4d;
                var meterY = bodyY + node.Height - (isCostEmphasized ? 9d : 7d);
                var secondaryLabels = BuildSecondaryLabels(node);
                var hasIndexLabel = !string.IsNullOrWhiteSpace(secondaryLabels.IndexLabel);
                var nodeMetaY = contentY + (hasIndexLabel ? 62 : 47);
                var nodeMetricRows = BuildNodeMetricRows(node);
                var nodeMetricY = nodeMetaY;
                NodeMetricGroup? previousNodeMetricGroup = null;

                <g class="@GetNodeClass(node, isSelected, isScan, hasDashedOutline, isCriticalNode, costEmphasisLevel)"
                   data-node-id="@node.NodeId"
                   data-cost-emphasis="@costEmphasisLevel"
                   @onclick="@(() => SelectNode(node.NodeId))"
                   @onmouseenter="@(() => HoverNode(node.NodeId))"
                   @onmouseleave="ClearHoveredNode">
                    @if (isCostEmphasized)
                    {
                        <rect x="@(bodyX - 13)" y="@(bodyY - 13)" width="@(node.Width + 26)" height="@(node.Height + 26)" rx="30" ry="30" class="node-cost-halo" fill="@costEmphasisStyle.HaloFill" stroke="@costEmphasisStyle.HaloStroke" />
                    }
                    @if (isScan)
                    {
                        <rect x="@(bodyX - 9)" y="@(bodyY - 9)" width="@(node.Width + 18)" height="@(node.Height + 18)" rx="27" ry="27" class="scan-frame" />
                    }
                    <rect x="@bodyX" y="@bodyY" width="@node.Width" height="@node.Height" rx="18" ry="18" class="node-body" fill="@GetCardFill(node, isSelected)" stroke="@GetCardStroke(node, isSelected)" />
                    <rect x="@(bodyX + 1)" y="@(bodyY + 1)" width="@(node.Width - 2)" height="@headerBandHeight" rx="17" ry="17" class="node-header-band" />
                    <rect x="@(bodyX + 1)" y="@(bodyY + 12)" width="@(node.Width - 2)" height="13" class="node-header-band-base" />
                    <rect x="@bodyX" y="@accentY" width="@node.Width" height="5" class="node-accent" fill="@GetAccentFill(node, icon)" />
                    <text x="@nodeIdTextX" y="@nodeIdTextY" class="node-id-label">@nodeIdLabel</text>
                    @if (hasDashedOutline)
                    {
                        <rect x="@(bodyX - 6)" y="@(bodyY - 6)" width="@(node.Width + 12)" height="@(node.Height + 12)" rx="24" ry="24" class="node-cost-highlight" stroke="@costEmphasisStyle.OutlineStroke" />
                    }
                    @if (isCriticalNode)
                    {
                        <rect x="@(bodyX - 3)" y="@(bodyY - 3)" width="@(node.Width + 6)" height="@(node.Height + 6)" rx="21" ry="21" class="node-critical-path" />
                    }
                    <rect x="@iconTileX" y="@iconTileY" width="34" height="34" rx="10" ry="10" class="node-icon-tile" fill="@GetIconTileFill(isSelected, isCriticalNode)" />

                    <g class="node-icon" stroke="@GetAccentFill(node, icon)" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                        @switch (icon.Kind)
                        {
                            case OperatorIconKind.Seek:
                                <circle cx="@(iconOriginX + 7)" cy="@(iconOriginY + 7)" r="6"></circle>
                                <line x1="@(iconOriginX + 12)" y1="@(iconOriginY + 12)" x2="@(iconOriginX + 19)" y2="@(iconOriginY + 19)"></line>
                                <line x1="@(iconOriginX + 3)" y1="@(iconOriginY + 7)" x2="@(iconOriginX + 11)" y2="@(iconOriginY + 7)"></line>
                                <line x1="@(iconOriginX + 7)" y1="@(iconOriginY + 3)" x2="@(iconOriginX + 7)" y2="@(iconOriginY + 11)"></line>
                                break;
                            case OperatorIconKind.Scan:
                                <rect x="@iconOriginX" y="@iconOriginY" width="20" height="18" rx="3"></rect>
                                <line x1="@(iconOriginX + 7)" y1="@iconOriginY" x2="@(iconOriginX + 7)" y2="@(iconOriginY + 18)"></line>
                                <line x1="@(iconOriginX + 14)" y1="@iconOriginY" x2="@(iconOriginX + 14)" y2="@(iconOriginY + 18)"></line>
                                <line x1="@iconOriginX" y1="@(iconOriginY + 6)" x2="@(iconOriginX + 20)" y2="@(iconOriginY + 6)"></line>
                                <line x1="@iconOriginX" y1="@(iconOriginY + 12)" x2="@(iconOriginX + 20)" y2="@(iconOriginY + 12)"></line>
                                break;
                            case OperatorIconKind.NestedLoops:
                                <circle cx="@(iconOriginX + 7)" cy="@(iconOriginY + 9)" r="5"></circle>
                                <circle cx="@(iconOriginX + 15)" cy="@(iconOriginY + 9)" r="5"></circle>
                                <path d="@($"M {iconOriginX + 3} {iconOriginY + 18} C {iconOriginX + 6} {iconOriginY + 13}, {iconOriginX + 16} {iconOriginY + 13}, {iconOriginX + 19} {iconOriginY + 18}")"></path>
                                break;
                            case OperatorIconKind.MergeJoin:
                                <path d="@($"M {iconOriginX} {iconOriginY + 4} L {iconOriginX + 8} {iconOriginY + 12} L {iconOriginX} {iconOriginY + 20}")"></path>
                                <path d="@($"M {iconOriginX + 20} {iconOriginY + 4} L {iconOriginX + 12} {iconOriginY + 12} L {iconOriginX + 20} {iconOriginY + 20}")"></path>
                                <line x1="@(iconOriginX + 8)" y1="@(iconOriginY + 12)" x2="@(iconOriginX + 12)" y2="@(iconOriginY + 12)"></line>
                                break;
                            case OperatorIconKind.HashMatch:
                                <path d="@($"M {iconOriginX + 10} {iconOriginY} L {iconOriginX + 20} {iconOriginY + 6} L {iconOriginX + 20} {iconOriginY + 18} L {iconOriginX + 10} {iconOriginY + 24} L {iconOriginX} {iconOriginY + 18} L {iconOriginX} {iconOriginY + 6} Z")"></path>
                                <line x1="@(iconOriginX + 6)" y1="@(iconOriginY + 6)" x2="@(iconOriginX + 14)" y2="@(iconOriginY + 18)"></line>
                                <line x1="@(iconOriginX + 14)" y1="@(iconOriginY + 6)" x2="@(iconOriginX + 6)" y2="@(iconOriginY + 18)"></line>
                                break;
                            case OperatorIconKind.Sort:
                                <line x1="@iconOriginX" y1="@(iconOriginY + 5)" x2="@(iconOriginX + 17)" y2="@(iconOriginY + 5)"></line>
                                <line x1="@iconOriginX" y1="@(iconOriginY + 12)" x2="@(iconOriginX + 12)" y2="@(iconOriginY + 12)"></line>
                                <line x1="@iconOriginX" y1="@(iconOriginY + 19)" x2="@(iconOriginX + 7)" y2="@(iconOriginY + 19)"></line>
                                <path d="@($"M {iconOriginX + 19} {iconOriginY + 3} L {iconOriginX + 23} {iconOriginY + 5} L {iconOriginX + 19} {iconOriginY + 7}")"></path>
                                <path d="@($"M {iconOriginX + 14} {iconOriginY + 10} L {iconOriginX + 18} {iconOriginY + 12} L {iconOriginX + 14} {iconOriginY + 14}")"></path>
                                <path d="@($"M {iconOriginX + 9} {iconOriginY + 17} L {iconOriginX + 13} {iconOriginY + 19} L {iconOriginX + 9} {iconOriginY + 21}")"></path>
                                break;
                            case OperatorIconKind.Filter:
                                <path d="@($"M {iconOriginX} {iconOriginY + 2} L {iconOriginX + 20} {iconOriginY + 2} L {iconOriginX + 12} {iconOriginY + 12} L {iconOriginX + 12} {iconOriginY + 20} L {iconOriginX + 8} {iconOriginY + 18} L {iconOriginX + 8} {iconOriginY + 12} Z")"></path>
                                break;
                            case OperatorIconKind.ComputeScalar:
                                <rect x="@iconOriginX" y="@iconOriginY" width="20" height="20" rx="4"></rect>
                                <line x1="@(iconOriginX + 6)" y1="@(iconOriginY + 10)" x2="@(iconOriginX + 14)" y2="@(iconOriginY + 10)"></line>
                                <line x1="@(iconOriginX + 10)" y1="@(iconOriginY + 6)" x2="@(iconOriginX + 10)" y2="@(iconOriginY + 14)"></line>
                                <circle cx="@(iconOriginX + 16)" cy="@(iconOriginY + 16)" r="1.5" fill="@GetAccentFill(node, icon)" stroke="none"></circle>
                                break;
                            case OperatorIconKind.Parallelism:
                                <path d="@($"M {iconOriginX + 10} {iconOriginY + 2} L {iconOriginX + 10} {iconOriginY + 10}")"></path>
                                <path d="@($"M {iconOriginX + 10} {iconOriginY + 10} L {iconOriginX + 4} {iconOriginY + 18}")"></path>
                                <path d="@($"M {iconOriginX + 10} {iconOriginY + 10} L {iconOriginX + 16} {iconOriginY + 18}")"></path>
                                <path d="@($"M {iconOriginX + 10} {iconOriginY + 2} L {iconOriginX + 7} {iconOriginY + 5}")"></path>
                                <path d="@($"M {iconOriginX + 10} {iconOriginY + 2} L {iconOriginX + 13} {iconOriginY + 5}")"></path>
                                break;
                            case OperatorIconKind.Aggregate:
                                <rect x="@iconOriginX" y="@(iconOriginY + 12)" width="4" height="8" rx="1"></rect>
                                <rect x="@(iconOriginX + 7)" y="@(iconOriginY + 8)" width="4" height="12" rx="1"></rect>
                                <rect x="@(iconOriginX + 14)" y="@(iconOriginY + 4)" width="4" height="16" rx="1"></rect>
                                break;
                            case OperatorIconKind.KeyLookup:
                                <circle cx="@(iconOriginX + 7)" cy="@(iconOriginY + 9)" r="4.5"></circle>
                                <line x1="@(iconOriginX + 11)" y1="@(iconOriginY + 9)" x2="@(iconOriginX + 20)" y2="@(iconOriginY + 9)"></line>
                                <line x1="@(iconOriginX + 16)" y1="@(iconOriginY + 9)" x2="@(iconOriginX + 16)" y2="@(iconOriginY + 14)"></line>
                                <line x1="@(iconOriginX + 19)" y1="@(iconOriginY + 9)" x2="@(iconOriginX + 19)" y2="@(iconOriginY + 12)"></line>
                                break;
                            case OperatorIconKind.Spool:
                                <ellipse cx="@(iconOriginX + 10)" cy="@(iconOriginY + 4)" rx="8" ry="3.5"></ellipse>
                                <path d="@($"M {iconOriginX + 2} {iconOriginY + 4} V {iconOriginY + 18} C {iconOriginX + 2} {iconOriginY + 22}, {iconOriginX + 18} {iconOriginY + 22}, {iconOriginX + 18} {iconOriginY + 18} V {iconOriginY + 4}")"></path>
                                <ellipse cx="@(iconOriginX + 10)" cy="@(iconOriginY + 18)" rx="8" ry="3.5"></ellipse>
                                break;
                            case OperatorIconKind.ConstantScan:
                                <rect x="@iconOriginX" y="@iconOriginY" width="20" height="20" rx="4"></rect>
                                <line x1="@(iconOriginX + 5)" y1="@(iconOriginY + 7)" x2="@(iconOriginX + 15)" y2="@(iconOriginY + 7)"></line>
                                <line x1="@(iconOriginX + 5)" y1="@(iconOriginY + 12)" x2="@(iconOriginX + 15)" y2="@(iconOriginY + 12)"></line>
                                break;
                            default:
                                <rect x="@iconOriginX" y="@iconOriginY" width="20" height="20" rx="4"></rect>
                                <path d="@($"M {iconOriginX + 5} {iconOriginY + 14} L {iconOriginX + 10} {iconOriginY + 5} L {iconOriginX + 15} {iconOriginY + 14} Z")"></path>
                                break;
                        }
                    </g>
                    @if (node.IsParallel)
                    {
                        <g class="parallel-badge">
                            <rect x="@parallelBadgeX" y="@parallelBadgeY" width="27" height="25" rx="7" ry="7" class="parallel-badge-body" />
                            <line x1="@(parallelBadgeX + 7)" y1="@(parallelBadgeY + 6)" x2="@(parallelBadgeX + 7)" y2="@(parallelBadgeY + 16)" class="parallel-badge-thread" />
                            <line x1="@(parallelBadgeX + 13.5)" y1="@(parallelBadgeY + 4)" x2="@(parallelBadgeX + 13.5)" y2="@(parallelBadgeY + 16)" class="parallel-badge-thread" />
                            <line x1="@(parallelBadgeX + 20)" y1="@(parallelBadgeY + 6)" x2="@(parallelBadgeX + 20)" y2="@(parallelBadgeY + 16)" class="parallel-badge-thread" />
                            <path d="@($"M {parallelBadgeX + 5} {parallelBadgeY + 18} C {parallelBadgeX + 10} {parallelBadgeY + 22}, {parallelBadgeX + 17} {parallelBadgeY + 22}, {parallelBadgeX + 22} {parallelBadgeY + 18}")" class="parallel-badge-flow" />
                            <path d="@($"M {parallelBadgeX + 19} {parallelBadgeY + 16} L {parallelBadgeX + 23} {parallelBadgeY + 18} L {parallelBadgeX + 19} {parallelBadgeY + 20}")" class="parallel-badge-flow" />
                        </g>
                    }
                    @if (node.HasImplicitConversion)
                    {
                        <g class="implicit-conversion-badge">
                            <title>Implicit conversion</title>
                            <rect x="@implicitConversionBadgeX" y="@implicitConversionBadgeY" width="27" height="25" rx="7" ry="7" class="implicit-conversion-badge-body" />
                            <path d="@($"M {implicitConversionBadgeX + 7} {implicitConversionBadgeY + 8} H {implicitConversionBadgeX + 18} L {implicitConversionBadgeX + 15} {implicitConversionBadgeY + 5} M {implicitConversionBadgeX + 18} {implicitConversionBadgeY + 8} L {implicitConversionBadgeX + 15} {implicitConversionBadgeY + 11}")" class="implicit-conversion-badge-arrow" />
                            <path d="@($"M {implicitConversionBadgeX + 20} {implicitConversionBadgeY + 16} H {implicitConversionBadgeX + 9} L {implicitConversionBadgeX + 12} {implicitConversionBadgeY + 13} M {implicitConversionBadgeX + 9} {implicitConversionBadgeY + 16} L {implicitConversionBadgeX + 12} {implicitConversionBadgeY + 19}")" class="implicit-conversion-badge-arrow" />
                            <text x="@(implicitConversionBadgeX + 13.5d)" y="@(implicitConversionBadgeY + 15d)" class="implicit-conversion-badge-type">T</text>
                        </g>
                    }

                    <text x="@contentX" y="@contentY" class="graph-title">
                        @Trim(node.PrimaryLabel, 30)
                    </text>
                    <text x="@contentX" y="@(contentY + 21)" class="graph-subtitle">
                        @secondaryLabels.TableLabel
                    </text>
                    <text x="@contentX" y="@(contentY + 36)" class="graph-subtitle graph-index-label">
                        @secondaryLabels.IndexLabel
                    </text>
                    @if (nodeMetricRows.Count > 0 && HasVisibleSecondaryLabel(secondaryLabels))
                    {
                        var headerSeparatorY = nodeMetricY - MetricSeparatorBottomMargin;
                        <line x1="@contentX" y1="@headerSeparatorY" x2="@(bodyX + node.Width - 18)" y2="@headerSeparatorY" class="node-metric-separator" />
                    }
                    @foreach (var metric in nodeMetricRows)
                    {
                        if (previousNodeMetricGroup.HasValue && previousNodeMetricGroup.Value != metric.Group)
                        {
                            var separatorY = ResolveMetricSeparatorY(nodeMetricY, metric.Spacing);
                            <line x1="@contentX" y1="@separatorY" x2="@(bodyX + node.Width - 18)" y2="@separatorY" class="node-metric-separator" />
                        }

                        nodeMetricY += metric.Spacing;
                        previousNodeMetricGroup = metric.Group;
                        <g class="node-metric-row">
                            <text x="@contentX" y="@nodeMetricY" class="graph-meta graph-rows node-metric-label">
                                @metric.Label
                            </text>
                            <text x="@metricValueX" y="@nodeMetricY" class="graph-meta graph-rows node-metric-value">
                                @metric.Value
                            </text>
                        </g>
                    }
                    <rect x="@(bodyX + 16)" y="@meterY" width="@(node.Width - 32)" height="@meterHeight" rx="@(meterHeight / 2)" ry="@(meterHeight / 2)" class="@GetMeterTrackClass(isCostEmphasized)" />
                    <rect x="@(bodyX + 16)" y="@meterY" width="@meterWidth" height="@meterHeight" rx="@(meterHeight / 2)" ry="@(meterHeight / 2)" class="node-meter-fill" fill="@GetMeterFill(node, icon, costEmphasisLevel)" />
                </g>
            }
            </svg>
        </div>
    </div>
}

@code {
    [Parameter]
    public StatementGraphLayout? Layout { get; set; }

    [Parameter]
    public string? SelectedNodeId { get; set; }

    [Parameter]
    public string? SelectedStatementId { get; set; }

    [Parameter]
    public int CostHighlightThresholdPercent { get; set; } = 20;

    [Parameter]
    public bool ShowCriticalPath { get; set; } = true;

    [Parameter]
    public string? ExportBaseName { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectNode { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectStatement { get; set; }

    [Parameter]
    public EventCallback<string?> OnHoverNode { get; set; }

    private const decimal ZoomStep = 0.2m;
    private const decimal MinZoom = 0.6m;
    private const decimal MaxZoom = 2.2m;
    private const double MetricSeparatorBottomMargin = 15d;
    private decimal zoom = 1.0m;
    private string? previousStatementId;
    private string? previousSelectedNodeId;
    private bool panInitialized;
    private bool resetViewportPending;
    private bool focusSelectedNodePending;
    private ElementReference graphShellRef;

    private ElementReference svgRef;

    private string? exportError;

    private sealed record EdgeFlowLabel(
        string EstimatedRowsName,
        string EstimatedRowsValue,
        string ActualRowsName,
        string ActualRowsValue,
        double X,
        double Y,
        double Width,
        double Height,
        double LabelX,
        double ValueX);

    private bool CanZoomIn => zoom < MaxZoom;

    private bool CanZoomOut => zoom > MinZoom;

    private string ZoomLabel => $"{zoom:P0}";

    private string MarkerId => $"plan-arrow-{Layout?.StatementId ?? "default"}";

    private string EstimatedMarkerId => $"plan-arrow-estimated-{Layout?.StatementId ?? "default"}";

    private string ActualMarkerId => $"plan-arrow-actual-{Layout?.StatementId ?? "default"}";

    private double ScaledWidth => Layout is null ? 0 : Layout.Width * (double)zoom;

    private double ScaledHeight => Layout is null ? 0 : Layout.Height * (double)zoom;

    protected override void OnParametersSet()
    {
        if (!string.Equals(previousStatementId, Layout?.StatementId, StringComparison.Ordinal))
        {
            zoom = 1.0m;
            previousStatementId = Layout?.StatementId;
            resetViewportPending = true;
        }

        if (!string.Equals(previousSelectedNodeId, SelectedNodeId, StringComparison.Ordinal))
        {
            previousSelectedNodeId = SelectedNodeId;
            focusSelectedNodePending = !string.IsNullOrWhiteSpace(SelectedNodeId);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Layout is not null && !panInitialized)
        {
            await JS.InvokeVoidAsync("mssqlPlanViewerGraphPan.init", graphShellRef);
            panInitialized = true;
        }

        if (Layout is not null && resetViewportPending)
        {
            await JS.InvokeVoidAsync("mssqlPlanViewerGraphPan.reset", graphShellRef);
            resetViewportPending = false;
        }

        if (Layout is not null && focusSelectedNodePending && !string.IsNullOrWhiteSpace(SelectedNodeId))
        {
            await JS.InvokeVoidAsync("mssqlPlanViewerGraphPan.focusNode", graphShellRef, SelectedNodeId);
            focusSelectedNodePending = false;
        }
    }

    private Task SelectNode(string nodeId) => OnSelectNode.InvokeAsync(nodeId);

    private Task SelectStatement(string statementId) => OnSelectStatement.InvokeAsync(statementId);

    private Task HoverNode(string nodeId) => OnHoverNode.InvokeAsync(nodeId);

    private Task ClearHoveredNode() => OnHoverNode.InvokeAsync((string?)null);

    private async Task ExportSvg()
    {
        exportError = null;
        try
        {
            await JS.InvokeVoidAsync("mssqlPlanViewerExport.exportSvg", svgRef, $"{ExportFileBaseName}.svg");
        }
        catch (Exception)
        {
            exportError = "Unable to export the graph as SVG.";
        }
    }

    private async Task ExportPng()
    {
        exportError = null;
        try
        {
            var succeeded = await JS.InvokeAsync<bool>("mssqlPlanViewerExport.exportPng", svgRef, $"{ExportFileBaseName}.png");
            if (!succeeded)
            {
                exportError = "PNG export is unavailable in this browser. Try SVG instead.";
            }
        }
        catch (Exception)
        {
            exportError = "Unable to export the graph as PNG. Try SVG instead.";
        }
    }

    private string ExportFileBaseName
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(ExportBaseName))
            {
                return ExportBaseName;
            }

            return PlanFileNameBuilder.BuildBaseName("plan-graph", Layout?.StatementId, "plan-graph");
        }
    }

    private void ZoomIn()
    {
        if (CanZoomIn)
        {
            zoom = Math.Min(MaxZoom, zoom + ZoomStep);
        }
    }

    private void ZoomOut()
    {
        if (CanZoomOut)
        {
            zoom = Math.Max(MinZoom, zoom - ZoomStep);
        }
    }

    private void ResetZoom()
    {
        zoom = 1.0m;
        resetViewportPending = true;
    }

    private static string BuildEdgePath(GraphEdgeLayout edge, GraphLayoutDirection direction) =>
        direction == GraphLayoutDirection.HorizontalSsms
            ? BuildHorizontalEdgePath(edge)
            : BuildVerticalEdgePath(edge);

    private static string BuildVerticalEdgePath(GraphEdgeLayout edge)
    {
        var controlY1 = edge.Y1 + 36;
        var controlY2 = edge.Y2 - 36;
        return $"M {edge.X1} {edge.Y1} C {edge.X1} {controlY1}, {edge.X2} {controlY2}, {edge.X2} {edge.Y2}";
    }

    private static string BuildHorizontalEdgePath(GraphEdgeLayout edge)
    {
        var controlX1 = edge.X1 - 36;
        var controlX2 = edge.X2 + 36;
        return $"M {edge.X1} {edge.Y1} C {controlX1} {edge.Y1}, {controlX2} {edge.Y2}, {edge.X2} {edge.Y2}";
    }

    private static string BuildEdgeStrokeStyle(GraphEdgeLayout edge)
    {
        var strokeWidth = edge.StrokeWidth.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        return $"stroke: {ResolveEdgeColor(edge)}; stroke-width: {strokeWidth}px";
    }

    private static string BuildCriticalEdgeOutlineStyle(GraphEdgeLayout edge)
    {
        var strokeWidth = Math.Max(edge.StrokeWidth + 4d, 7d)
            .ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        return $"stroke-width: {strokeWidth}px";
    }

    private string ResolveEdgeMarkerId(GraphEdgeLayout edge)
    {
        if (edge.ActualRows.HasValue)
        {
            return ActualMarkerId;
        }

        return edge.EstimatedRows.HasValue ? EstimatedMarkerId : MarkerId;
    }

    private static string ResolveEdgeColor(GraphEdgeLayout edge) =>
        edge.ActualRows.HasValue
            ? "#0f766e"
            : "#94a3b8";

    private static EdgeFlowLabel? BuildEdgeFlowLabel(GraphEdgeLayout edge, GraphLayoutDirection direction)
    {
        if (!edge.EstimatedRows.HasValue && !edge.ActualRows.HasValue)
        {
            return null;
        }

        const string estimatedRowsName = "Est rows";
        const string actualRowsName = "Act rows";
        var estimatedRowsValue = PlanDisplayFormatter.FormatNumber(edge.EstimatedRows);
        var actualRowsValue = PlanDisplayFormatter.FormatNumber(edge.ActualRows);
        var maxNameLength = Math.Max(estimatedRowsName.Length, actualRowsName.Length);
        var maxValueLength = Math.Max(estimatedRowsValue.Length, actualRowsValue.Length);
        var width = Math.Clamp(((maxNameLength + maxValueLength) * 6.3d) + 34d, 112d, 192d);
        var (x, y) = ResolveEdgeFlowLabelPosition(edge, direction, width);

        return new EdgeFlowLabel(
            estimatedRowsName,
            estimatedRowsValue,
            actualRowsName,
            actualRowsValue,
            X: x,
            Y: y,
            Width: width,
            Height: 44d,
            LabelX: x - (width / 2d) + 12d,
            ValueX: x + (width / 2d) - 12d);
    }

    private static (double X, double Y) ResolveEdgeFlowLabelPosition(GraphEdgeLayout edge, GraphLayoutDirection direction, double width)
    {
        var lineX = (edge.X1 + edge.X2) / 2d;
        var lineY = (edge.Y1 + edge.Y2) / 2d;
        var horizontalClearance = 30d + (edge.StrokeWidth / 2d);
        var verticalClearance = 18d + (edge.StrokeWidth / 2d);

        return direction == GraphLayoutDirection.HorizontalSsms
            ? (lineX, lineY - horizontalClearance)
            : (lineX + (width / 2d) + verticalClearance, lineY);
    }

    private string GetNodeClass(GraphNodeLayout node, bool isSelected, bool isScan, bool hasDashedOutline, bool isCriticalNode, GraphCostEmphasisLevel costEmphasisLevel)
    {
        var classes = new List<string> { "graph-node" };

        if (isSelected)
        {
            classes.Add("selected");
        }

        if (node.HasWarnings)
        {
            classes.Add("warning");
        }

        if (isScan)
        {
            classes.Add("scan");
        }

        if (hasDashedOutline)
        {
            classes.Add("cost-over-threshold");
        }

        if (isCriticalNode)
        {
            classes.Add("critical-path");
        }

        var costClass = GraphCostEmphasis.GetStyle(costEmphasisLevel).CssClass;
        if (!string.IsNullOrWhiteSpace(costClass))
        {
            classes.Add(costClass);
        }

        return string.Join(" ", classes);
    }

    private static string GetStatementNodeClass(bool isSelected) =>
        isSelected ? "statement-graph-node selected" : "statement-graph-node";

    private static string GetCardFill(GraphNodeLayout node, bool isSelected)
    {
        if (isSelected)
        {
            return "#eff6ff";
        }

        if (node.HasWarnings)
        {
            return "#fffbeb";
        }

        return "#ffffff";
    }

    private static string GetCardStroke(GraphNodeLayout node, bool isSelected)
    {
        if (isSelected)
        {
            return "#1d4ed8";
        }

        if (node.HasWarnings)
        {
            return "#f59e0b";
        }

        return "#cbd5e1";
    }

    private static string GetAccentFill(GraphNodeLayout node, OperatorIconDescriptor icon)
    {
        if (node.HasWarnings)
        {
            return "#f59e0b";
        }

        return node.CostRatio switch
        {
            >= 0.60m => icon.AccentColor,
            >= 0.30m => "#38bdf8",
            _ => "#94a3b8"
        };
    }

    private static string GetMeterFill(GraphNodeLayout node, OperatorIconDescriptor icon, GraphCostEmphasisLevel costEmphasisLevel) =>
        GraphCostEmphasis.IsEmphasized(costEmphasisLevel)
            ? GraphCostEmphasis.GetStyle(costEmphasisLevel).MeterFill
            : GetAccentFill(node, icon);

    private static string GetIconTileFill(bool isSelected, bool isCriticalNode)
    {
        if (isSelected)
        {
            return "#dbeafe";
        }

        return isCriticalNode ? "#ede9fe" : "#f8fafc";
    }

    private GraphCostEmphasisLevel ResolveCostEmphasisLevel(GraphNodeLayout node) =>
        GraphCostEmphasis.Resolve(node.CostRatio, CostHighlightThresholdPercent);

    private static string GetMeterTrackClass(bool isCostEmphasized) =>
        isCostEmphasized ? "node-meter-track is-emphasized" : "node-meter-track";

    private static bool IsScanOperator(GraphNodeLayout node, OperatorIconDescriptor icon) =>
        icon.Kind is OperatorIconKind.Scan or OperatorIconKind.ConstantScan
        || node.PhysicalOp.Contains("Scan", StringComparison.OrdinalIgnoreCase)
        || node.LogicalOp.Contains("Scan", StringComparison.OrdinalIgnoreCase);

    private static double ResolveMetricSeparatorY(double currentMetricY, double nextMetricSpacing) =>
        currentMetricY + Math.Max(4d, nextMetricSpacing - MetricSeparatorBottomMargin);

    private static IReadOnlyList<NodeMetricRow> BuildNodeMetricRows(GraphNodeLayout node)
    {
        var rows = new List<NodeMetricRow>
        {
            new("Cost", PlanDisplayFormatter.FormatPercent(node.CostRatio), 0, NodeMetricGroup.Cost)
        };

        AddNumberMetric(rows, "Average Row Size", node.AverageRowSize, 22, NodeMetricGroup.AverageRowSize);
        AddNumberMetric(rows, "Estimated Rows", node.EstimatedRows, 22, NodeMetricGroup.Estimated);
        AddNumberMetric(rows, "Estimated Executions", node.EstimatedExecutions, 14, NodeMetricGroup.Estimated);
        AddTextMetric(rows, "Estimated Mode", node.EstimatedExecutionMode, 14, NodeMetricGroup.Estimated);
        AddNumberMetric(rows, "Actual Rows", node.ActualRows, 22, NodeMetricGroup.Actual);
        AddNumberMetric(rows, "Actual Executions", node.ActualExecutions, 14, NodeMetricGroup.Actual);
        AddTextMetric(rows, "Actual Mode", node.ActualExecutionMode, 14, NodeMetricGroup.Actual);
        AddNumberMetric(rows, "Actual Logical Reads", node.ActualLogicalReads, 14, NodeMetricGroup.Actual);
        AddNumberMetric(rows, "Actual Physical Reads", node.ActualPhysicalReads, 14, NodeMetricGroup.Actual);
        AddMillisecondsMetric(rows, "Actual CPU", node.ActualCpuMs, 14, NodeMetricGroup.Actual);
        AddMillisecondsMetric(rows, "Actual Elapsed", node.ActualElapsedMs, 14, NodeMetricGroup.Actual);

        return rows;
    }

    private static void AddNumberMetric(ICollection<NodeMetricRow> rows, string label, double? value, double spacing, NodeMetricGroup group)
    {
        if (value.HasValue)
        {
            rows.Add(new NodeMetricRow(label, PlanDisplayFormatter.FormatNumber(value), spacing, group));
        }
    }

    private static void AddTextMetric(ICollection<NodeMetricRow> rows, string label, string? value, double spacing, NodeMetricGroup group)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            rows.Add(new NodeMetricRow(label, value, spacing, group));
        }
    }

    private static void AddMillisecondsMetric(ICollection<NodeMetricRow> rows, string label, double? value, double spacing, NodeMetricGroup group)
    {
        if (value.HasValue)
        {
            rows.Add(new NodeMetricRow(label, FormatMilliseconds(value.Value), spacing, group));
        }
    }

    private static string FormatMilliseconds(double value) =>
        $"{PlanDisplayFormatter.FormatNumber(value)} ms";

    private static NodeSecondaryLabels BuildSecondaryLabels(GraphNodeLayout node)
    {
        const string separator = " / ";
        var separatorIndex = node.SecondaryLabel.IndexOf(separator, StringComparison.Ordinal);
        if (separatorIndex < 0)
        {
            return new NodeSecondaryLabels(Trim(node.SecondaryLabel, 30), null);
        }

        var tableLabel = node.SecondaryLabel[..separatorIndex];
        var indexLabel = node.SecondaryLabel[(separatorIndex + separator.Length)..];
        return new NodeSecondaryLabels(Trim(tableLabel, 30), Trim(indexLabel, 30));
    }

    private static bool HasVisibleSecondaryLabel(NodeSecondaryLabels labels) =>
        !string.IsNullOrWhiteSpace(labels.TableLabel) || !string.IsNullOrWhiteSpace(labels.IndexLabel);

    private enum NodeMetricGroup
    {
        Cost,
        AverageRowSize,
        Estimated,
        Actual
    }

    private sealed record NodeMetricRow(string Label, string Value, double Spacing, NodeMetricGroup Group);

    private sealed record NodeSecondaryLabels(string TableLabel, string? IndexLabel);

    private static string Trim(string text, int maxLength) =>
        text.Length <= maxLength ? text : $"{text[..(maxLength - 1)]}…";
}
