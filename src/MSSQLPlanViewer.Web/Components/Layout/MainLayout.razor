@inherits LayoutComponentBase

<div class="page">
    <main>
        <div class="top-row">
            <div class="top-row-content">
                <div class="top-row-brand">
                    <div class="top-row-title">MSSQL Plan Viewer</div>
                    <div class="top-row-subtitle">SQL Server Showplan XML inspector</div>
                </div>
                <nav class="top-nav" aria-label="Primary">
                    <NavLink class="top-nav-link" href="" Match="NavLinkMatch.All">Plan Viewer</NavLink>
                    <NavLink class="top-nav-link" href="api">API</NavLink>
                </nav>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unexpected error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
