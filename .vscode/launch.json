{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MSSQL Plan Viewer (Dev Container)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build MSSQLPlanViewer.Web",
      "program": "${workspaceFolder}/src/MSSQLPlanViewer.Web/bin/Debug/net10.0/MSSQLPlanViewer.Web.dll",
      "args": [
        "--urls",
        "http://0.0.0.0:5293"
      ],
      "cwd": "${workspaceFolder}/src/MSSQLPlanViewer.Web",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+http://\\S+:([0-9]+)",
        "uriFormat": "http://localhost:%s"
      }
    }
  ]
}
