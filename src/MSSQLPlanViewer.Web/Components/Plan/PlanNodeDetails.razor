@if (Statement is null)
{
    <p class="empty-state">After you parse XML, statement and node details appear here.</p>
}
else if (Node is null)
{
    <div class="details-shell">
        <div class="details-heading">
            <div>
                <div class="details-label">Statement</div>
                <h3>@Statement.StatementType</h3>
                <p class="details-subtitle">@GetStatementElementLabel(Statement) #@Statement.StatementId</p>
            </div>
        </div>

        @{
            var visibleStatementProperties = GetVisibleStatementProperties(Statement);
        }

        @if (visibleStatementProperties.Count > 0)
        {
            <div class="xml-attributes-section">
                <div class="details-label">@GetStatementElementLabel(Statement) attributes (@FormatCount(visibleStatementProperties.Count))</div>
                @RenderXmlAttributesTable(visibleStatementProperties)
            </div>
        }

        @if (Statement.StatementSetOptionsProperties.Count > 0)
        {
            <div class="xml-attributes-section">
                <div class="details-label">StatementSetOptions attributes (@FormatCount(Statement.StatementSetOptionsProperties.Count))</div>
                @RenderXmlAttributesTable(Statement.StatementSetOptionsProperties)
            </div>
        }

        @if (Statement.Summary.QueryPlanProperties.Count > 0)
        {
            <div class="xml-attributes-section">
                <div class="details-label">QueryPlan attributes (@FormatCount(Statement.Summary.QueryPlanProperties.Count))</div>
                @RenderXmlAttributesTable(Statement.Summary.QueryPlanProperties)
            </div>
        }

        @for (var threadStatIndex = 0; threadStatIndex < Statement.Summary.ThreadStatProperties.Count; threadStatIndex++)
        {
            var threadStatProperties = Statement.Summary.ThreadStatProperties[threadStatIndex];
            var threadStatLabel = Statement.Summary.ThreadStatProperties.Count == 1
                ? "ThreadStat"
                : $"ThreadStat #{(threadStatIndex + 1).ToString(System.Globalization.CultureInfo.InvariantCulture)}";

            <div class="xml-attributes-section">
                <div class="details-label">@threadStatLabel attributes (@FormatCount(threadStatProperties.Count))</div>
                @RenderXmlAttributesTable(threadStatProperties)
            </div>
        }

        @if (Statement.Summary.MemoryGrantInfoProperties.Count > 0)
        {
            <div class="xml-attributes-section">
                <div class="details-label">MemoryGrantInfo attributes (@FormatCount(Statement.Summary.MemoryGrantInfoProperties.Count))</div>
                @RenderXmlAttributesTable(Statement.Summary.MemoryGrantInfoProperties)
            </div>
        }

        @if (Statement.Summary.OptimizerHardwareDependentProperties.Count > 0)
        {
            <div class="xml-attributes-section">
                <div class="details-label">OptimizerHardwareDependentProperties attributes (@FormatCount(Statement.Summary.OptimizerHardwareDependentProperties.Count))</div>
                @RenderXmlAttributesTable(Statement.Summary.OptimizerHardwareDependentProperties)
            </div>
        }

    </div>
}
else
{
    <div class="details-shell">
        <div class="details-heading">
            <div>
                <div class="details-label">Operator</div>
                <h3>@Node.PhysicalOp</h3>
                <p class="details-subtitle">@Node.LogicalOp</p>
            </div>
            @if (Node.DetailXmlAttributes.Count > 0)
            {
                <button type="button" class="btn btn-outline-secondary btn-sm details-toggle" @onclick="ToggleDetail">
                    @(showDetail ? "Hide detail" : "Detail")
                </button>
            }
        </div>

        <dl class="details-list">
            @foreach (var property in Node.Properties)
            {
                <div class="details-row">
                    <dt>@property.Name</dt>
                    <dd>@FormatDetailsValue(property.Value)</dd>
                </div>
            }
        </dl>

        @if (Node.RuntimeMetrics.Threads.Count > 1)
        {
            <div class="thread-counters-section">
                <div class="details-label">Per-thread counters</div>
                <div class="details-table-shell">
                    <table class="table table-sm align-middle details-table thread-counters-table">
                        <thead>
                            <tr>
                                <th scope="col">Thread</th>
                                <th scope="col" class="numeric-cell">Actual rows</th>
                                <th scope="col" class="numeric-cell">Rows read</th>
                                <th scope="col" class="numeric-cell">Executions</th>
                                <th scope="col" class="numeric-cell">Logical reads</th>
                                <th scope="col" class="numeric-cell">CPU ms</th>
                                <th scope="col" class="numeric-cell">Elapsed ms</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var thread in Node.RuntimeMetrics.Threads)
                            {
                                <tr>
                                    <td>@FormatThreadId(thread.ThreadId)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualRows)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualRowsRead)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualExecutions)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualLogicalReads)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualCpuMs)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualElapsedMs)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (Node.XmlAttributes.Count > 0)
        {
            <div class="xml-attributes-section">
                <div class="details-label">XML attributes (@FormatCount(Node.XmlAttributes.Count))</div>
                @RenderXmlAttributesTable(Node.XmlAttributes)
            </div>
        }

        @if (showDetail && Node.DetailXmlAttributes.Count > 0)
        {
            <div class="xml-attributes-section detail-xml-attributes-section">
                <div class="details-label">All XML attributes (@FormatCount(Node.DetailXmlAttributes.Count))</div>
                @RenderXmlAttributesTable(Node.DetailXmlAttributes)
            </div>
        }

        @if (Node.Warnings.Count > 0)
        {
            <div class="warning-section">
                <div class="details-label">Warnings</div>
                <div class="warning-list">
                    @foreach (var warning in Node.Warnings)
                    {
                        <span class="warning-pill" title="@warning.Details">@warning.Name</span>
                    }
                </div>
            </div>
        }

    </div>
}

@code {
    [Parameter]
    public StatementPlan? Statement { get; set; }

    [Parameter]
    public PlanNode? Node { get; set; }

    private bool showDetail;

    private string? previousNodeId;

    protected override void OnParametersSet()
    {
        var currentNodeId = Node?.NodeId;
        if (!string.Equals(previousNodeId, currentNodeId, StringComparison.Ordinal))
        {
            previousNodeId = currentNodeId;
            showDetail = false;
        }
    }

    private void ToggleDetail() =>
        showDetail = !showDetail;

    private static string FormatCount(int count) =>
        count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture);

    private static string GetStatementElementLabel(StatementPlan statement) =>
        string.IsNullOrWhiteSpace(statement.StatementElementName) ? "Statement" : statement.StatementElementName;

    private static IReadOnlyList<PlanProperty> GetVisibleStatementProperties(StatementPlan statement) =>
        statement.StatementProperties
            .Where(property => !string.Equals(property.Name, "StatementText", StringComparison.OrdinalIgnoreCase))
            .ToArray();

    private static RenderFragment RenderXmlAttributesTable(IReadOnlyList<PlanProperty> xmlAttributes) => @<div class="details-table-shell">
        <table class="table table-sm align-middle details-table xml-attributes-table">
            <thead>
                <tr>
                    <th scope="col">Attribute</th>
                    <th scope="col">Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var xmlAttribute in xmlAttributes)
                {
                    <tr>
                        <td class="xml-attribute-name">@xmlAttribute.Name</td>
                        <td class="xml-attribute-value">@FormatDetailsValue(xmlAttribute.Value)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>;

    private static string FormatThreadId(int threadId) =>
        threadId == 0
            ? "0 (coordinator)"
            : threadId.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string FormatNumber(double? value) =>
        PlanDisplayFormatter.FormatNumber(value);

    private static string FormatDetailsValue(string value) =>
        PlanDisplayFormatter.FormatNumericText(value);
}
