@page "/"
@inject IJSRuntime JS
@inject IShowplanParser ShowplanParser
@inject IPlanComparisonService PlanComparisonService
@inject PlanWorkspaceService PlanWorkspace
@inject IEstimatedShowplanProvider EstimatedShowplanProvider
@inject ILogger<Home> Logger
@using MSSQLPlanViewer.Web.Showplans

<PageTitle>MSSQL Plan Viewer</PageTitle>

<div class="viewer-page with-details">
    <section class="hero card-surface">
        <div>
            <div class="eyebrow">SQL Server Showplan XML</div>
            <h1>MSSQL Plan Viewer</h1>
        </div>
        <div class="hero-actions">
            <button class="btn btn-outline-secondary" @onclick="ClearInput">Clear</button>
        </div>
    </section>

    <section class="input-card card-surface">
        <div class="section-header">
            <div>
                <h2>@(ActiveInputMode == PlanInputMode.ShowplanXml ? "Showplan XML Input" : "Query Input")</h2>
            </div>
            @if (ActiveInputMode == PlanInputMode.ShowplanXml)
            {
                <button class="btn btn-primary" @onclick="ParsePlan">
                    Parse
                </button>
            }
            else
            {
                <button class="btn btn-primary" @onclick="FetchEstimatedPlan" disabled="@IsFetchingEstimatedPlan">
                    @(IsFetchingEstimatedPlan ? "Getting plan..." : "Get estimated plan")
                </button>
            }
        </div>

        <div class="input-mode-toggle" role="group" aria-label="Plan input mode">
            <button type="button"
                    class="input-mode-button @(ActiveInputMode == PlanInputMode.ShowplanXml ? "is-active" : null)"
                    aria-pressed="@(ActiveInputMode == PlanInputMode.ShowplanXml)"
                    @onclick="() => SetInputMode(PlanInputMode.ShowplanXml)">
                Showplan XML
            </button>
            <button type="button"
                    class="input-mode-button @(ActiveInputMode == PlanInputMode.Query ? "is-active" : null)"
                    aria-pressed="@(ActiveInputMode == PlanInputMode.Query)"
                    @onclick="() => SetInputMode(PlanInputMode.Query)">
                Query
            </button>
        </div>

        @if (ActiveInputMode == PlanInputMode.ShowplanXml)
        {
            <textarea class="plan-input"
                      @bind="XmlInput"
                      @bind:event="oninput"
                      spellcheck="false"
                      placeholder="Paste SQL Server Showplan XML here."></textarea>

            <label class="file-dropzone" @ref="fileDropzoneRef">
                <InputFile OnChange="HandleFilesSelected" multiple accept=".sqlplan,.xml" />
                <span class="file-dropzone-text">Drop .sqlplan or .xml files here, or click to choose</span>
            </label>

            @if (FileLoadMessages.Count > 0)
            {
                <ul class="file-load-messages" aria-live="polite">
                    @foreach (var message in FileLoadMessages)
                    {
                        <li class="file-load-message @(message.IsError ? "is-error" : "is-success")">@message.Text</li>
                    }
                </ul>
            }

            @if (!string.IsNullOrWhiteSpace(ParseError))
            {
                <div class="alert alert-danger parse-error" role="alert">
                    @ParseError
                </div>
            }
        }
        else
        {
            <div class="query-form">
                <div class="query-form-grid">
                    <label class="query-field query-field-wide">
                        <span>Connection string</span>
                        <div class="connection-input-group">
                            <input class="form-control"
                                   type="@(ShowConnectionString ? "text" : "password")"
                                   autocomplete="off"
                                   @bind="QueryConnectionString"
                                   @bind:event="oninput"
                                   placeholder="Server=.;Database=AdventureWorks;Integrated Security=true;TrustServerCertificate=true;" />
                            <label class="connection-toggle">
                                <input type="checkbox" class="form-check-input" @bind="ShowConnectionString" />
                                <span>Show</span>
                            </label>
                        </div>
                    </label>
                    <label class="query-field">
                        <span>Plan label</span>
                        <input class="form-control"
                               @bind="QueryPlanLabel"
                               @bind:event="oninput"
                               placeholder="Optional" />
                    </label>
                    <label class="query-field timeout-field">
                        <span>Timeout</span>
                        <div class="input-group input-group-sm">
                            <input type="number"
                                   class="form-control"
                                   min="@SqlEstimatedShowplanProvider.MinCommandTimeoutSeconds"
                                   max="@SqlEstimatedShowplanProvider.MaxCommandTimeoutSeconds"
                                   step="1"
                                   @bind="QueryCommandTimeoutSeconds" />
                            <span class="input-group-text">s</span>
                        </div>
                    </label>
                </div>

                <textarea class="plan-input query-input"
                          @bind="QueryInput"
                          @bind:event="oninput"
                          spellcheck="false"
                          placeholder="SELECT ..."></textarea>
            </div>

            @if (EstimatedPlanMessages.Count > 0)
            {
                <ul class="file-load-messages" aria-live="polite">
                    @foreach (var message in EstimatedPlanMessages)
                    {
                        <li class="file-load-message @(message.IsError ? "is-error" : "is-success")">@message.Text</li>
                    }
                </ul>
            }

            @if (!string.IsNullOrWhiteSpace(EstimatedPlanError))
            {
                <div class="alert alert-danger parse-error" role="alert">
                    @EstimatedPlanError
                </div>
            }
        }
    </section>

    @if (Plans.Count > 0)
    {
        <section class="plan-tabs card-surface" role="tablist" aria-label="Loaded plans">
            @foreach (var plan in Plans)
            {
                var isActive = plan.Id == ActivePlanId;
                <div class="plan-tab @(isActive ? "is-active" : null)" role="tab" aria-selected="@isActive">
                    <button type="button" class="plan-tab-label" @onclick="() => SelectPlan(plan.Id)">@plan.Label</button>
                    <button type="button"
                            class="plan-tab-close"
                            aria-label="@($"Close {plan.Label}")"
                            @onclick="() => ClosePlan(plan.Id)">&times;</button>
                </div>
            }
        </section>
    }

    @if (Plans.Count > 1)
    {
        <section class="card-surface compare-card">
            <div class="section-header compact">
                <div>
                    <span class="summary-label">Compare plans</span>
                </div>
            </div>
            <div class="compare-selectors">
                <label class="compare-selector">
                    <span>Plan A</span>
                    <select class="form-select form-select-sm" value="@ComparePlanAId" @onchange="OnComparePlanAChanged">
                        @foreach (var plan in Plans)
                        {
                            <option value="@plan.Id">@plan.Label</option>
                        }
                    </select>
                </label>
                <label class="compare-selector">
                    <span>Plan B</span>
                    <select class="form-select form-select-sm" value="@ComparePlanBId" @onchange="OnComparePlanBChanged">
                        @foreach (var plan in Plans)
                        {
                            <option value="@plan.Id">@plan.Label</option>
                        }
                    </select>
                </label>
            </div>

            @{
                var comparison = BuildComparison();
            }
            @if (comparison is not null)
            {
                <div class="summary-table-shell">
                    <table class="table table-sm align-middle summary-table compare-table">
                        <thead>
                            <tr>
                                <th scope="col">Metric</th>
                                <th scope="col" class="numeric">Plan A</th>
                                <th scope="col" class="numeric">Plan B</th>
                                <th scope="col" class="numeric">Delta</th>
                                <th scope="col" class="numeric">Delta %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var metric in comparison.Metrics)
                            {
                                <tr>
                                    <td>@metric.MetricName</td>
                                    <td class="numeric-cell">@FormatMetricValue(metric.ValueA, metric.IsInteger)</td>
                                    <td class="numeric-cell">@FormatMetricValue(metric.ValueB, metric.IsInteger)</td>
                                    <td class="numeric-cell @GetDeltaClass(metric.Delta)">@FormatMetricDelta(metric.Delta, metric.IsInteger)</td>
                                    <td class="numeric-cell @GetDeltaClass(metric.Delta)">@FormatMetricPercent(metric.DeltaPercent)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (Document is not null && SelectedStatement is not null)
    {
        var warningRows = GetWarningRows(SelectedStatement);
        var statementItems = GetVisibleProperties(SelectedStatement.StatementProperties);
        var statementSetOptionsItems = GetVisibleProperties(SelectedStatement.StatementSetOptionsProperties);
        var statementSummaryItems = GetStatementSummaryItems(SelectedStatement);
        var queryTimeStatsItems = GetVisibleProperties(SelectedStatement.Summary.QueryTimeStatsProperties);
        var queryPlanItems = GetVisibleProperties(SelectedStatement.Summary.QueryPlanProperties);
        var threadStatItems = SelectedStatement.Summary.ThreadStatProperties
            .Select(GetVisibleProperties)
            .Where(properties => properties.Count > 0)
            .ToArray();
        var memoryGrantInfoItems = GetVisibleProperties(SelectedStatement.Summary.MemoryGrantInfoProperties);
        var optimizerHardwareItems = GetVisibleProperties(SelectedStatement.Summary.OptimizerHardwareDependentProperties);
        var missingIndexItems = SelectedStatement.Summary.MissingIndexesEntries;
        var accessedObjectItems = SelectedStatement.Summary.AccessedObjectEntries;
        var accessedIndexItems = SelectedStatement.Summary.AccessedIndexEntries;
        var seekScanPredicateItems = SelectedStatement.Summary.SeekScanPredicateEntries;
        var implicitConversionItems = SelectedStatement.Summary.ImplicitConversionEntries;
        var parameterListItems = SelectedStatement.Summary.ParameterListEntries;
        var statementDiagnostics = ActivePlan?.Diagnostics
            .Where(diagnostic => diagnostic.StatementId == SelectedStatement.StatementId)
            .ToArray() ?? Array.Empty<PlanDiagnostic>();
        var combinedPlanDetailRows = BuildCombinedPlanDetailRows(
            SelectedStatement.StatementElementName,
            statementItems,
            statementSetOptionsItems,
            queryTimeStatsItems,
            statementSummaryItems,
            queryPlanItems,
            threadStatItems,
            memoryGrantInfoItems,
            optimizerHardwareItems);
        var hasAccessSummaryItems = accessedObjectItems.Count > 0
            || accessedIndexItems.Count > 0
            || missingIndexItems.Count > 0
            || parameterListItems.Count > 0
            || seekScanPredicateItems.Count > 0
            || implicitConversionItems.Count > 0;
        var activeAccessSummaryTab = ResolveAccessSummaryTab(
            accessedObjectItems.Count,
            accessedIndexItems.Count,
            missingIndexItems.Count,
            parameterListItems.Count,
            seekScanPredicateItems.Count,
            implicitConversionItems.Count);
        var optimizerStatsUsageItems = SelectedStatement.Summary.OptimizerStatsUsageEntries;
        var waitStatsItems = SelectedStatement.Summary.WaitStatsEntries;
        var hasOptimizationSummaryItems = optimizerStatsUsageItems.Count > 0
            || waitStatsItems.Count > 0
            || warningRows.Count > 0;
        var activeOptimizationSummaryTab = ResolveOptimizationSummaryTab(
            optimizerStatsUsageItems.Count,
            waitStatsItems.Count,
            warningRows.Count);

        <section class="summary-grid summary-grid-top">
            <div class="summary-card card-surface">
                <span class="summary-label">Schema</span>
                <strong>@Document.Metadata.SchemaVersion</strong>
                <small class="summary-link">
                    @if (PlanDisplayFormatter.TryGetSafeHttpUrl(Document.Metadata.NamespaceUri, out var namespaceUrl))
                    {
                        <a href="@namespaceUrl" target="_blank" rel="noopener noreferrer">@Document.Metadata.NamespaceUri</a>
                    }
                    else
                    {
                        <span>@Document.Metadata.NamespaceUri</span>
                    }
                </small>
            </div>
            <div class="summary-card card-surface">
                <span class="summary-label">Statements</span>
                <div class="summary-count-line">
                    <strong>@GetBatchCount(Document).ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                    <span>Batch</span>
                    <strong>@Document.Statements.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                    <span>Statement</span>
                </div>
            </div>
            <div class="summary-card summary-statement-card card-surface">
                <span class="summary-label">Selected statement</span>
                <strong>Batch #@(SelectedStatement.BatchNumber.ToString(System.Globalization.CultureInfo.InvariantCulture))</strong>
                <small>#@SelectedStatement.StatementId - @SelectedStatement.StatementType</small>
                @if (Document.Statements.Count > 1)
                {
                    <select class="form-select form-select-sm statement-select" value="@SelectedStatementKey" @onchange="OnStatementChanged">
                        @foreach (var statement in Document.Statements)
                        {
                            <option value="@statement.StatementKey">@BuildStatementSelectionLabel(statement)</option>
                        }
                    </select>
                }
            </div>
        </section>

        <section class="statement-text card-surface">
            <div class="section-header compact">
                <div>
                    <h2>Statement text</h2>
                </div>
            </div>
            <pre>@SelectedStatement.StatementText</pre>
        </section>

        <section class="summary-grid summary-grid-bottom">
            <div class="summary-card card-surface">
                <span class="summary-label">Operators</span>
                <strong>@SelectedStatement.Nodes.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                <small>Total: @Document.TotalNodeCount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</small>
            </div>
            <div class="summary-card card-surface">
                <span class="summary-label">Warnings</span>
                <strong>@SelectedStatement.WarningCount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                <small>Total: @Document.TotalWarningCount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</small>
            </div>
        </section>

        @if (hasAccessSummaryItems)
        {
            <section class="card-surface summary-table-card access-summary-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">Access summary</span>
                    </div>
                    <div class="access-tabs" role="tablist" aria-label="Access summary views">
                        <button type="button"
                                role="tab"
                                class="@GetAccessSummaryTabClass(AccessSummaryTab.AccessedObjects, activeAccessSummaryTab)"
                                aria-selected="@(activeAccessSummaryTab == AccessSummaryTab.AccessedObjects)"
                                disabled="@(accessedObjectItems.Count == 0)"
                                @onclick="@(() => SetAccessSummaryTab(AccessSummaryTab.AccessedObjects))">
                            Accessed objects
                            <span>@accessedObjectItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                        <button type="button"
                                role="tab"
                                class="@GetAccessSummaryTabClass(AccessSummaryTab.AccessedIndexes, activeAccessSummaryTab)"
                                aria-selected="@(activeAccessSummaryTab == AccessSummaryTab.AccessedIndexes)"
                                disabled="@(accessedIndexItems.Count == 0)"
                                @onclick="@(() => SetAccessSummaryTab(AccessSummaryTab.AccessedIndexes))">
                            Accessed indexes
                            <span>@accessedIndexItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                        <button type="button"
                                role="tab"
                                class="@GetAccessSummaryTabClass(AccessSummaryTab.MissingIndexes, activeAccessSummaryTab)"
                                aria-selected="@(activeAccessSummaryTab == AccessSummaryTab.MissingIndexes)"
                                disabled="@(missingIndexItems.Count == 0)"
                                @onclick="@(() => SetAccessSummaryTab(AccessSummaryTab.MissingIndexes))">
                            Missing indexes
                            <span>@missingIndexItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                        <button type="button"
                                role="tab"
                                class="@GetAccessSummaryTabClass(AccessSummaryTab.ParameterList, activeAccessSummaryTab)"
                                aria-selected="@(activeAccessSummaryTab == AccessSummaryTab.ParameterList)"
                                disabled="@(parameterListItems.Count == 0)"
                                @onclick="@(() => SetAccessSummaryTab(AccessSummaryTab.ParameterList))">
                            ParameterList
                            <span>@parameterListItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                        <button type="button"
                                role="tab"
                                class="@GetAccessSummaryTabClass(AccessSummaryTab.SeekScanPredicates, activeAccessSummaryTab)"
                                aria-selected="@(activeAccessSummaryTab == AccessSummaryTab.SeekScanPredicates)"
                                disabled="@(seekScanPredicateItems.Count == 0)"
                                @onclick="@(() => SetAccessSummaryTab(AccessSummaryTab.SeekScanPredicates))">
                            Seek/Scan predicates
                            <span>@seekScanPredicateItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                        <button type="button"
                                role="tab"
                                class="@GetAccessSummaryTabClass(AccessSummaryTab.ImplicitConversions, activeAccessSummaryTab)"
                                aria-selected="@(activeAccessSummaryTab == AccessSummaryTab.ImplicitConversions)"
                                disabled="@(implicitConversionItems.Count == 0)"
                                @onclick="@(() => SetAccessSummaryTab(AccessSummaryTab.ImplicitConversions))">
                            Implicit conversions
                            <span>@implicitConversionItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                    </div>
                </div>

                <div class="summary-table-shell">
                    @switch (activeAccessSummaryTab)
                    {
                        case AccessSummaryTab.AccessedObjects:
                            <table class="table table-sm align-middle summary-table access-object-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Table</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in accessedObjectItems)
                                    {
                                        <tr>
                                            <td class="object-cell">@BuildAccessedObjectName(item)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                        case AccessSummaryTab.AccessedIndexes:
                            <table class="table table-sm align-middle summary-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Node</th>
                                        <th scope="col">Physical operation</th>
                                        <th scope="col">Logical operation</th>
                                        <th scope="col">Table</th>
                                        <th scope="col">Index</th>
                                        <th scope="col">Index kind</th>
                                        <th scope="col" class="numeric-cell">Est. rows</th>
                                        <th scope="col" class="numeric-cell">Est. I/O cost</th>
                                        <th scope="col" class="numeric-cell">Actual rows</th>
                                        <th scope="col" class="numeric-cell">Actual logical reads</th>
                                        <th scope="col" class="numeric-cell">Actual physical reads</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in accessedIndexItems)
                                    {
                                        <tr class="@(string.Equals(item.NodeId, SelectedNodeId, StringComparison.Ordinal) ? "selected-warning-row" : null)">
                                            <td class="warning-node-cell">
                                                <button type="button"
                                                        class="warning-node-button"
                                                        @onclick="@(() => HandleReferencedNodeSelected(item.NodeId))">
                                                    Node @item.NodeId
                                                </button>
                                            </td>
                                            <td>@FormatSummaryValue(item.PhysicalOp)</td>
                                            <td>@FormatSummaryValue(item.LogicalOp)</td>
                                            <td class="object-cell">@BuildAccessedIndexTableName(item)</td>
                                            <td class="object-cell">@FormatSummaryValue(item.Index)</td>
                                            <td>@FormatSummaryValue(item.IndexKind)</td>
                                            <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.EstimatedRows))</td>
                                            <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatCost(item.EstimatedIoCost))</td>
                                            <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.ActualRows))</td>
                                            <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.ActualLogicalReads))</td>
                                            <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.ActualPhysicalReads))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                        case AccessSummaryTab.MissingIndexes:
                            <table class="table table-sm align-middle summary-table missing-index-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Impact</th>
                                        <th scope="col">Object</th>
                                        <th scope="col">Equality</th>
                                        <th scope="col">Inequality</th>
                                        <th scope="col">Include</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in missingIndexItems)
                                    {
                                        <tr>
                                            <td class="numeric-cell">@FormatSummaryValue(item.Impact)</td>
                                            <td class="object-cell">@item.ObjectName</td>
                                            <td class="details-cell">@FormatSummaryValue(item.EqualityColumns)</td>
                                            <td class="details-cell">@FormatSummaryValue(item.InequalityColumns)</td>
                                            <td class="details-cell">@FormatSummaryValue(item.IncludeColumns)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                        case AccessSummaryTab.ParameterList:
                            <table class="table table-sm align-middle summary-table parameter-list-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Parameter</th>
                                        <th scope="col">Data type</th>
                                        <th scope="col">Compiled value</th>
                                        <th scope="col">Runtime value</th>
                                        <th scope="col">Nullable</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in parameterListItems)
                                    {
                                        <tr>
                                            <td>@FormatSummaryValue(item.Parameter)</td>
                                            <td>@FormatSummaryValue(item.DataType)</td>
                                            <td class="details-cell">@FormatSummaryValue(item.CompiledValue)</td>
                                            <td class="details-cell">@FormatSummaryValue(item.RuntimeValue)</td>
                                            <td>@FormatSummaryValue(item.IsNullable)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                        case AccessSummaryTab.SeekScanPredicates:
                            <table class="table table-sm align-middle summary-table seek-scan-predicate-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Node</th>
                                        <th scope="col">Physical operation</th>
                                        <th scope="col">Logical operation</th>
                                        <th scope="col">Table</th>
                                        <th scope="col">Index</th>
                                        <th scope="col">Index kind</th>
                                        <th scope="col">Seek predicate</th>
                                        <th scope="col">Predicate</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in seekScanPredicateItems)
                                    {
                                        <tr class="@(string.Equals(item.NodeId, SelectedNodeId, StringComparison.Ordinal) ? "selected-warning-row" : null)">
                                            <td class="warning-node-cell">
                                                <button type="button"
                                                        class="warning-node-button"
                                                        @onclick="@(() => HandleReferencedNodeSelected(item.NodeId))">
                                                    Node @item.NodeId
                                                </button>
                                            </td>
                                            <td>@FormatSummaryValue(item.PhysicalOp)</td>
                                            <td>@FormatSummaryValue(item.LogicalOp)</td>
                                            <td class="object-cell">@BuildSeekScanPredicateTableName(item)</td>
                                            <td class="object-cell">@FormatSummaryValue(item.Index)</td>
                                            <td>@FormatSummaryValue(item.IndexKind)</td>
                                            <td class="predicate-cell">@FormatSummaryValue(item.SeekPredicate)</td>
                                            <td class="predicate-cell">@FormatSummaryValue(item.Predicate)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                        case AccessSummaryTab.ImplicitConversions:
                            <table class="table table-sm align-middle summary-table implicit-conversion-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Node</th>
                                        <th scope="col">Physical operation</th>
                                        <th scope="col">Logical operation</th>
                                        <th scope="col">Object</th>
                                        <th scope="col">Source</th>
                                        <th scope="col">Expression</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in implicitConversionItems)
                                    {
                                        <tr class="@(string.Equals(item.NodeId, SelectedNodeId, StringComparison.Ordinal) ? "selected-warning-row" : null)">
                                            <td class="warning-node-cell">
                                                <button type="button"
                                                        class="warning-node-button"
                                                        @onclick="@(() => HandleReferencedNodeSelected(item.NodeId))">
                                                    Node @item.NodeId
                                                </button>
                                            </td>
                                            <td>@FormatSummaryValue(item.PhysicalOp)</td>
                                            <td>@FormatSummaryValue(item.LogicalOp)</td>
                                            <td class="object-cell">@FormatSummaryValue(BuildImplicitConversionObjectName(item))</td>
                                            <td>@FormatSummaryValue(item.Source)</td>
                                            <td class="predicate-cell">@FormatSummaryValue(item.Expression)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                    }
                </div>
            </section>
        }

        @if (hasOptimizationSummaryItems)
        {
            <section class="card-surface summary-table-card optimization-summary-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">Optimization summary</span>
                    </div>
                    <div class="access-tabs" role="tablist" aria-label="Optimization summary views">
                        <button type="button"
                                role="tab"
                                class="@GetOptimizationSummaryTabClass(OptimizationSummaryTab.OptimizerStatsUsage, activeOptimizationSummaryTab)"
                                aria-selected="@(activeOptimizationSummaryTab == OptimizationSummaryTab.OptimizerStatsUsage)"
                                disabled="@(optimizerStatsUsageItems.Count == 0)"
                                @onclick="@(() => SetOptimizationSummaryTab(OptimizationSummaryTab.OptimizerStatsUsage))">
                            OptimizerStatsUsage
                            <span>@optimizerStatsUsageItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                        <button type="button"
                                role="tab"
                                class="@GetOptimizationSummaryTabClass(OptimizationSummaryTab.WaitStats, activeOptimizationSummaryTab)"
                                aria-selected="@(activeOptimizationSummaryTab == OptimizationSummaryTab.WaitStats)"
                                disabled="@(waitStatsItems.Count == 0)"
                                @onclick="@(() => SetOptimizationSummaryTab(OptimizationSummaryTab.WaitStats))">
                            Wait stats
                            <span>@waitStatsItems.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                        <button type="button"
                                role="tab"
                                class="@GetOptimizationSummaryTabClass(OptimizationSummaryTab.WarningDetails, activeOptimizationSummaryTab)"
                                aria-selected="@(activeOptimizationSummaryTab == OptimizationSummaryTab.WarningDetails)"
                                disabled="@(warningRows.Count == 0)"
                                @onclick="@(() => SetOptimizationSummaryTab(OptimizationSummaryTab.WarningDetails))">
                            Warning details
                            <span>@warningRows.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </button>
                    </div>
                </div>
                <div class="summary-table-shell">
                    @switch (activeOptimizationSummaryTab)
                    {
                        case OptimizationSummaryTab.OptimizerStatsUsage:
                            <table class="table table-sm align-middle summary-table optimizer-stats-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Table</th>
                                        <th scope="col">Statistics</th>
                                        <th scope="col">Last update</th>
                                        <th scope="col" class="numeric-cell">Modification count</th>
                                        <th scope="col">Last sample</th>
                                        <th scope="col" class="numeric-cell">Sampling %</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in optimizerStatsUsageItems)
                                    {
                                        <tr>
                                            <td>@BuildOptimizerStatsUsageTableName(item)</td>
                                            <td>@FormatSummaryValue(item.Statistics)</td>
                                            <td>@FormatSummaryValue(item.LastUpdate)</td>
                                            <td class="numeric-cell">@FormatSummaryValue(item.StatisticsModificationCount)</td>
                                            <td>@FormatSummaryValue(item.LastSample)</td>
                                            <td class="numeric-cell">@FormatSummaryValue(item.SamplingPercent)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                        case OptimizationSummaryTab.WaitStats:
                            <table class="table table-sm align-middle summary-table wait-stats-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col">Wait type</th>
                                        <th scope="col" class="numeric-cell">WaitTimeMs</th>
                                        <th scope="col" class="numeric-cell">WaitCount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in waitStatsItems)
                                    {
                                        <tr>
                                            <td class="object-cell">@item.WaitType</td>
                                            <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.WaitTimeMs))</td>
                                            <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.WaitCount))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                        case OptimizationSummaryTab.WarningDetails:
                            <table class="table table-sm align-middle summary-table warning-details-table" role="tabpanel">
                                <thead>
                                    <tr>
                                        <th scope="col" class="warning-node-col">Node</th>
                                        <th scope="col">Operator</th>
                                        <th scope="col">Warning</th>
                                        <th scope="col">Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in warningRows)
                                    {
                                        <tr class="@(string.Equals(row.NodeId, SelectedNodeId, StringComparison.Ordinal) ? "selected-warning-row" : null)">
                                            <td class="warning-node-cell">
                                                @if (row.NodeId is null)
                                                {
                                                    <span class="warning-statement-label">Statement</span>
                                                }
                                                else
                                                {
                                                    <button type="button"
                                                            class="warning-node-button"
                                                            @onclick="@(() => HandleReferencedNodeSelected(row.NodeId!))">
                                                        Node @row.NodeId
                                                    </button>
                                                }
                                            </td>
                                            <td class="warning-operator-cell">@row.Operator</td>
                                            <td class="warning-name-cell">@row.Warning</td>
                                            <td class="warning-details-cell">@row.Details</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            break;
                    }
                </div>
            </section>
        }

        <div class="viewer-grid @(SelectedStatement is not null ? "with-details" : null)">
            <div class="viewer-main">
                <section class="card-surface graph-panel-card" @ref="graphPanelRef">
                    <div class="section-header">
                        <div>
                            <h2>Graphical plan</h2>
                        </div>
                        <div class="graph-header-actions">
                            <div class="section-chips">
                                <span class="chip">@SelectedStatement!.Nodes.Count operators</span>
                                <span class="chip">@SelectedStatement.Edges.Count edges</span>
                                @if (HighlightedCostNodeCount > 0)
                                {
                                    <span class="chip chip-emphasis">@HighlightedCostNodeCount high cost</span>
                                }
                            </div>
                            <div class="graph-layout-control" role="group" aria-label="Graph layout direction">
                                <span class="graph-threshold-label">Layout</span>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button"
                                            class="btn @(CurrentGraphLayoutDirection == GraphLayoutDirection.HorizontalSsms ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick="@(() => SetGraphLayoutDirection(GraphLayoutDirection.HorizontalSsms))">
                                        Horizontal
                                    </button>
                                    <button type="button"
                                            class="btn @(CurrentGraphLayoutDirection == GraphLayoutDirection.Vertical ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick="@(() => SetGraphLayoutDirection(GraphLayoutDirection.Vertical))">
                                        Vertical
                                    </button>
                                </div>
                            </div>
                            <label class="graph-threshold-setting">
                                <span class="graph-threshold-label">Highlight cost &gt;</span>
                                <div class="input-group input-group-sm graph-threshold-input">
                                    <input type="number"
                                           class="form-control"
                                           min="0"
                                           max="100"
                                           step="1"
                                           @bind="GraphCostThresholdPercent" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </label>
                            <label class="graph-threshold-setting graph-critical-toggle">
                                <input type="checkbox" class="form-check-input" @bind="ShowCriticalPath" />
                                <span class="graph-threshold-label">Critical path (est. cost)</span>
                            </label>
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Reset graphical plan size"
                                    @onclick="ResetGraphPanelSizeAsync">
                                Reset size
                            </button>
                        </div>
                    </div>

                    <PlanGraphView @key="ActivePlanId"
                                   Layout="SelectedLayout"
                                   CostHighlightThresholdPercent="GraphCostThresholdPercent"
                                   ShowCriticalPath="ShowCriticalPath"
                                   SelectedNodeId="@SelectedNodeId"
                                   SelectedStatementId="@SelectedStatementDetailId"
                                   ExportBaseName="@BuildExportBaseName()"
                                   OnSelectNode="HandleGraphNodeSelected"
                                   OnSelectStatement="HandleGraphStatementSelected"
                                   OnHoverNode="HandleNodeHovered" />
                    <div class="graph-panel-resize-handle"
                         @ref="graphPanelResizeHandleRef"
                         role="button"
                         tabindex="0"
                         aria-label="Resize graphical plan section"></div>
                </section>

                <section class="card-surface table-panel-card" @ref="tablePanelRef">
                    <div class="section-header">
                        <div>
                            <h2>Table view</h2>
                        </div>
                        <div class="table-header-actions">
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    title="Reset table view size"
                                    @onclick="ResetTablePanelSizeAsync">
                                Reset size
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DownloadTableCsv" disabled="@(CurrentRows.Count == 0)">Download CSV</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DownloadTableMarkdown" disabled="@(CurrentRows.Count == 0)">Download Markdown</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DownloadTableJson" disabled="@(CurrentRows.Count == 0)">Download JSON</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CopyTableCsv" disabled="@(CurrentRows.Count == 0)">Copy</button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(TableActionMessage))
                    {
                        <p class="table-action-message" aria-live="polite">@TableActionMessage</p>
                    }

                    <PlanNodeTable @key="ActivePlanId"
                                   Rows="CurrentRows"
                                   SelectedNodeId="@SelectedNodeId"
                                   ExpandRequestVersion="TableExpandRequestVersion"
                                   ScrollRequestVersion="TableScrollRequestVersion"
                                   OnSelectNode="HandleTableNodeSelected"
                                   OnHoverNode="HandleNodeHovered" />
                    <div class="table-panel-resize-handle"
                         @ref="tablePanelResizeHandleRef"
                         role="button"
                         tabindex="0"
                         aria-label="Resize table view section"></div>
                </section>

            </div>
            @if (SelectedStatement is not null)
            {
                var showStatementDetails = IsStatementDetailsSelected && OverlayNode is null;
                var showDetails = OverlayNode is not null || showStatementDetails;
                <aside class="details-column">
                    @if (combinedPlanDetailRows.Count > 0)
                    {
                        <section class="card-surface summary-table-card plan-details-card details-plan-card">
                            <div class="section-header compact">
                                <div>
                                    <span class="summary-label">Plan details</span>
                                </div>
                            </div>
                            <div class="summary-table-shell">
                                <table class="table table-sm align-middle summary-table plan-detail-table">
                                    <thead>
                                        <tr>
                                            <th scope="col">Section</th>
                                            <th scope="col">Property</th>
                                            <th scope="col">Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in combinedPlanDetailRows)
                                        {
                                            <tr>
                                                @if (row.ShowSection)
                                                {
                                                    <td class="object-cell section-cell" rowspan="@row.SectionRowSpan">@row.Section</td>
                                                }
                                                <td>@row.Name</td>
                                                <td class="details-cell">
                                                    @if (IsPlanDetailsStatementTextRow(row))
                                                    {
                                                        <div class="@GetPlanDetailsStatementTextClass()">@GetPlanDetailsStatementTextValue(row.Value)</div>
                                                        @if (IsPlanDetailsStatementTextExpandable(row.Value))
                                                        {
                                                            <button type="button" class="btn btn-outline-secondary btn-sm plan-text-toggle" @onclick="TogglePlanDetailsStatementText">
                                                                @(IsPlanDetailsStatementTextExpanded ? "Collapse" : "Expand")
                                                            </button>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @row.Value
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    }
                    <section class="card-surface sticky-panel operator-pane" aria-live="polite" @ref="detailsPaneRef">
                        <div class="details-resizer"
                             @ref="detailsResizeHandleRef"
                             role="separator"
                             aria-label="Resize operator details panel"
                             aria-orientation="vertical"></div>
                        <div class="section-header compact">
                            <div>
                                <div class="eyebrow">Operator details</div>
                                <h2>@(OverlayNode?.PhysicalOp ?? (showStatementDetails ? $"{SelectedStatement.StatementType} statement" : "No operator selected"))</h2>
                            </div>
                            <div class="details-header-actions">
                                @if (showDetails)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CloseOverlay">Close</button>
                                }
                            </div>
                        </div>

                        @if (OverlayNode is not null)
                        {
                            <PlanNodeDetails Statement="SelectedStatement" Node="OverlayNode" />
                        }
                        else if (showStatementDetails)
                        {
                            <PlanNodeDetails Statement="SelectedStatement" />
                        }
                    </section>
                </aside>
            }
        </div>

        <section class="card-surface diagnostics-card">
            <div class="section-header compact">
                <div>
                    <span class="summary-label">Diagnostics</span>
                </div>
            </div>
            <PlanDiagnosticsPanel Diagnostics="statementDiagnostics" OnSelectNode="HandleReferencedNodeSelected" />
        </section>
    }
</div>
