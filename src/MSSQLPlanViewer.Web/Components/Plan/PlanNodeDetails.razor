@if (Statement is null)
{
    <p class="empty-state">After you parse XML, statement and node details appear here.</p>
}
else if (Node is null)
{
    <div class="details-shell">
        <div>
            <div class="details-label">Statement</div>
            <h3>#@Statement.StatementId - @Statement.StatementType</h3>
        </div>

        @if (Statement.Warnings.Count > 0)
        {
            <div class="warning-section">
                <div class="details-label">Statement warnings</div>
                <div class="warning-list">
                    @foreach (var warning in Statement.Warnings)
                    {
                        <span class="warning-pill">@warning.Name</span>
                    }
                </div>
            </div>
        }

        <div>
            <div class="details-label">Statement text</div>
            <pre class="details-code">@Statement.StatementText</pre>
        </div>
    </div>
}
else
{
    <div class="details-shell">
        <div>
            <div class="details-label">Operator</div>
            <h3>@Node.PhysicalOp</h3>
            <p class="details-subtitle">@Node.LogicalOp</p>
        </div>

        <dl class="details-list">
            @foreach (var property in Node.Properties)
            {
                <div class="details-row">
                    <dt>@property.Name</dt>
                    <dd>@property.Value</dd>
                </div>
            }
        </dl>

        @if (Node.XmlAttributes.Count > 0)
        {
            <div class="xml-attributes-section">
                <div class="details-label">XML attributes</div>
                <div class="details-table-shell">
                    <table class="table table-sm align-middle details-table xml-attributes-table">
                        <thead>
                            <tr>
                                <th scope="col">Attribute</th>
                                <th scope="col">Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var xmlAttribute in Node.XmlAttributes)
                            {
                                <tr>
                                    <td class="xml-attribute-name">@xmlAttribute.Name</td>
                                    <td class="xml-attribute-value">@xmlAttribute.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (Node.RuntimeMetrics.Threads.Count > 1)
        {
            var threadStatistics = ThreadDistributionStatistics.Compute(Node.RuntimeMetrics.Threads);
            <div class="thread-counters-section">
                <div class="details-label">Per-thread counters</div>
                @if (threadStatistics is not null)
                {
                    <div class="thread-skew-summary">
                        <span>@threadStatistics.WorkerThreadCount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture) workers</span>
                        <span>Max/avg @FormatNumber(threadStatistics.MaxToAverageRatio)</span>
                        <span>CV @FormatNumber(threadStatistics.CoefficientOfVariation)</span>
                    </div>
                }
                <div class="details-table-shell">
                    <table class="table table-sm align-middle details-table thread-counters-table">
                        <thead>
                            <tr>
                                <th scope="col">Thread</th>
                                <th scope="col" class="numeric-cell">Actual rows</th>
                                <th scope="col" class="numeric-cell">Rows read</th>
                                <th scope="col" class="numeric-cell">Executions</th>
                                <th scope="col" class="numeric-cell">Logical reads</th>
                                <th scope="col" class="numeric-cell">CPU ms</th>
                                <th scope="col" class="numeric-cell">Elapsed ms</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var thread in Node.RuntimeMetrics.Threads)
                            {
                                <tr>
                                    <td>@FormatThreadId(thread.ThreadId)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualRows)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualRowsRead)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualExecutions)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualLogicalReads)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualCpuMs)</td>
                                    <td class="numeric-cell">@FormatNumber(thread.ActualElapsedMs)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (Node.Warnings.Count > 0)
        {
            <div class="warning-section">
                <div class="details-label">Warnings</div>
                <div class="warning-list">
                    @foreach (var warning in Node.Warnings)
                    {
                        <span class="warning-pill" title="@warning.Details">@warning.Name</span>
                    }
                </div>
            </div>
        }

        @if (Statement.Warnings.Count > 0)
        {
            <div class="warning-section">
                <div class="details-label">Statement warnings</div>
                <div class="warning-list">
                    @foreach (var warning in Statement.Warnings)
                    {
                        <span class="warning-pill" title="@warning.Details">@warning.Name</span>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public StatementPlan? Statement { get; set; }

    [Parameter]
    public PlanNode? Node { get; set; }

    private static string FormatThreadId(int threadId) =>
        threadId == 0
            ? "0 (coordinator)"
            : threadId.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string FormatNumber(double? value) =>
        PlanDisplayFormatter.FormatNumber(value);
}
