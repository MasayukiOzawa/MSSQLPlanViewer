@page "/"
@inject IJSRuntime JS
@inject IShowplanParser ShowplanParser
@inject IPlanGraphLayoutService GraphLayoutService
@inject IPlanTableProjector TableProjector
@inject IPlanComparisonService PlanComparisonService
@inject IPlanDiagnosticsService PlanDiagnosticsService
@inject IEstimatedShowplanProvider EstimatedShowplanProvider
@inject ILogger<Home> Logger
@using MSSQLPlanViewer.Web.Showplans

<PageTitle>MSSQL Plan Viewer</PageTitle>

<div class="viewer-page with-details">
    <section class="hero card-surface">
        <div>
            <div class="eyebrow">SQL Server Showplan XML</div>
            <h1>MSSQL Plan Viewer</h1>
        </div>
        <div class="hero-actions">
            <button class="btn btn-outline-secondary" @onclick="ClearInput">Clear</button>
        </div>
    </section>

    <section class="input-card card-surface">
        <div class="section-header">
            <div>
                <h2>@(ActiveInputMode == PlanInputMode.ShowplanXml ? "Showplan XML Input" : "Query Input")</h2>
            </div>
            @if (ActiveInputMode == PlanInputMode.ShowplanXml)
            {
                <button class="btn btn-primary" @onclick="ParsePlan">
                    Parse
                </button>
            }
            else
            {
                <button class="btn btn-primary" @onclick="FetchEstimatedPlan" disabled="@IsFetchingEstimatedPlan">
                    @(IsFetchingEstimatedPlan ? "Getting plan..." : "Get estimated plan")
                </button>
            }
        </div>

        <div class="input-mode-toggle" role="group" aria-label="Plan input mode">
            <button type="button"
                    class="input-mode-button @(ActiveInputMode == PlanInputMode.ShowplanXml ? "is-active" : null)"
                    aria-pressed="@(ActiveInputMode == PlanInputMode.ShowplanXml)"
                    @onclick="() => SetInputMode(PlanInputMode.ShowplanXml)">
                Showplan XML
            </button>
            <button type="button"
                    class="input-mode-button @(ActiveInputMode == PlanInputMode.Query ? "is-active" : null)"
                    aria-pressed="@(ActiveInputMode == PlanInputMode.Query)"
                    @onclick="() => SetInputMode(PlanInputMode.Query)">
                Query
            </button>
        </div>

        @if (ActiveInputMode == PlanInputMode.ShowplanXml)
        {
            <textarea class="plan-input"
                      @bind="XmlInput"
                      @bind:event="oninput"
                      spellcheck="false"
                      placeholder="Paste SQL Server Showplan XML here."></textarea>

            <label class="file-dropzone" @ref="fileDropzoneRef">
                <InputFile OnChange="HandleFilesSelected" multiple accept=".sqlplan,.xml" />
                <span class="file-dropzone-text">Drop .sqlplan or .xml files here, or click to choose</span>
            </label>

            @if (FileLoadMessages.Count > 0)
            {
                <ul class="file-load-messages" aria-live="polite">
                    @foreach (var message in FileLoadMessages)
                    {
                        <li class="file-load-message @(message.IsError ? "is-error" : "is-success")">@message.Text</li>
                    }
                </ul>
            }

            @if (!string.IsNullOrWhiteSpace(ParseError))
            {
                <div class="alert alert-danger parse-error" role="alert">
                    @ParseError
                </div>
            }
        }
        else
        {
            <div class="query-form">
                <div class="query-form-grid">
                    <label class="query-field query-field-wide">
                        <span>Connection string</span>
                        <div class="connection-input-group">
                            <input class="form-control"
                                   type="@(ShowConnectionString ? "text" : "password")"
                                   autocomplete="off"
                                   @bind="QueryConnectionString"
                                   @bind:event="oninput"
                                   placeholder="Server=.;Database=AdventureWorks;Integrated Security=true;TrustServerCertificate=true;" />
                            <label class="connection-toggle">
                                <input type="checkbox" class="form-check-input" @bind="ShowConnectionString" />
                                <span>Show</span>
                            </label>
                        </div>
                    </label>
                    <label class="query-field">
                        <span>Plan label</span>
                        <input class="form-control"
                               @bind="QueryPlanLabel"
                               @bind:event="oninput"
                               placeholder="Optional" />
                    </label>
                    <label class="query-field timeout-field">
                        <span>Timeout</span>
                        <div class="input-group input-group-sm">
                            <input type="number"
                                   class="form-control"
                                   min="@SqlEstimatedShowplanProvider.MinCommandTimeoutSeconds"
                                   max="@SqlEstimatedShowplanProvider.MaxCommandTimeoutSeconds"
                                   step="1"
                                   @bind="QueryCommandTimeoutSeconds" />
                            <span class="input-group-text">s</span>
                        </div>
                    </label>
                </div>

                <textarea class="plan-input query-input"
                          @bind="QueryInput"
                          @bind:event="oninput"
                          spellcheck="false"
                          placeholder="SELECT ..."></textarea>
            </div>

            @if (EstimatedPlanMessages.Count > 0)
            {
                <ul class="file-load-messages" aria-live="polite">
                    @foreach (var message in EstimatedPlanMessages)
                    {
                        <li class="file-load-message @(message.IsError ? "is-error" : "is-success")">@message.Text</li>
                    }
                </ul>
            }

            @if (!string.IsNullOrWhiteSpace(EstimatedPlanError))
            {
                <div class="alert alert-danger parse-error" role="alert">
                    @EstimatedPlanError
                </div>
            }
        }
    </section>

    @if (Plans.Count > 0)
    {
        <section class="plan-tabs card-surface" role="tablist" aria-label="Loaded plans">
            @foreach (var plan in Plans)
            {
                var isActive = plan.Id == ActivePlanId;
                <div class="plan-tab @(isActive ? "is-active" : null)" role="tab" aria-selected="@isActive">
                    <button type="button" class="plan-tab-label" @onclick="() => SelectPlan(plan.Id)">@plan.Label</button>
                    <button type="button"
                            class="plan-tab-close"
                            aria-label="@($"Close {plan.Label}")"
                            @onclick="() => ClosePlan(plan.Id)">&times;</button>
                </div>
            }
        </section>
    }

    @if (Plans.Count > 1)
    {
        <section class="card-surface compare-card">
            <div class="section-header compact">
                <div>
                    <span class="summary-label">Compare plans</span>
                </div>
            </div>
            <div class="compare-selectors">
                <label class="compare-selector">
                    <span>Plan A</span>
                    <select class="form-select form-select-sm" value="@ComparePlanAId" @onchange="OnComparePlanAChanged">
                        @foreach (var plan in Plans)
                        {
                            <option value="@plan.Id">@plan.Label</option>
                        }
                    </select>
                </label>
                <label class="compare-selector">
                    <span>Plan B</span>
                    <select class="form-select form-select-sm" value="@ComparePlanBId" @onchange="OnComparePlanBChanged">
                        @foreach (var plan in Plans)
                        {
                            <option value="@plan.Id">@plan.Label</option>
                        }
                    </select>
                </label>
            </div>

            @{
                var comparison = BuildComparison();
            }
            @if (comparison is not null)
            {
                <div class="summary-table-shell">
                    <table class="table table-sm align-middle summary-table compare-table">
                        <thead>
                            <tr>
                                <th scope="col">Metric</th>
                                <th scope="col" class="numeric">Plan A</th>
                                <th scope="col" class="numeric">Plan B</th>
                                <th scope="col" class="numeric">Delta</th>
                                <th scope="col" class="numeric">Delta %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var metric in comparison.Metrics)
                            {
                                <tr>
                                    <td>@metric.MetricName</td>
                                    <td class="numeric-cell">@FormatMetricValue(metric.ValueA, metric.IsInteger)</td>
                                    <td class="numeric-cell">@FormatMetricValue(metric.ValueB, metric.IsInteger)</td>
                                    <td class="numeric-cell @GetDeltaClass(metric.Delta)">@FormatMetricDelta(metric.Delta, metric.IsInteger)</td>
                                    <td class="numeric-cell @GetDeltaClass(metric.Delta)">@FormatMetricPercent(metric.DeltaPercent)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

    @if (SelectedStatement is null)
    {
        <aside class="details-column">
            <section class="card-surface sticky-panel operator-pane" aria-live="polite" @ref="detailsPaneRef">
                <div class="details-resizer"
                     @ref="detailsResizeHandleRef"
                     role="separator"
                     aria-label="Resize operator details panel"
                     aria-orientation="vertical"></div>
                <div class="section-header compact">
                    <div>
                        <div class="eyebrow">Operator details</div>
                        <h2>No operator selected</h2>
                    </div>
                </div>
            </section>
        </aside>
    }

    @if (Document is not null && SelectedStatement is not null)
    {
        var warningRows = GetWarningRows(SelectedStatement);
        var statementSummaryItems = GetStatementSummaryItems(SelectedStatement);
        var queryTimeStatsItems = GetVisibleProperties(SelectedStatement.Summary.QueryTimeStatsProperties);
        var queryPlanItems = GetVisibleProperties(SelectedStatement.Summary.QueryPlanProperties);
        var memoryGrantInfoItems = GetVisibleProperties(SelectedStatement.Summary.MemoryGrantInfoProperties);
        var optimizerHardwareItems = GetVisibleProperties(SelectedStatement.Summary.OptimizerHardwareDependentProperties);
        var missingIndexItems = SelectedStatement.Summary.MissingIndexesEntries;
        var accessedObjectItems = SelectedStatement.Summary.AccessedObjectEntries;
        var statementDiagnostics = ActivePlan?.Diagnostics
            .Where(diagnostic => diagnostic.StatementId == SelectedStatement.StatementId)
            .ToArray() ?? Array.Empty<PlanDiagnostic>();
        var combinedPlanDetailRows = BuildCombinedPlanDetailRows(
            queryTimeStatsItems,
            statementSummaryItems,
            queryPlanItems,
            memoryGrantInfoItems,
            optimizerHardwareItems);

        <section class="summary-grid summary-grid-top">
            <div class="summary-card card-surface">
                <span class="summary-label">Schema</span>
                <strong>@Document.Metadata.SchemaVersion</strong>
                <small class="summary-link">
                    @if (PlanDisplayFormatter.TryGetSafeHttpUrl(Document.Metadata.NamespaceUri, out var namespaceUrl))
                    {
                        <a href="@namespaceUrl" target="_blank" rel="noopener noreferrer">@Document.Metadata.NamespaceUri</a>
                    }
                    else
                    {
                        <span>@Document.Metadata.NamespaceUri</span>
                    }
                </small>
            </div>
            <div class="summary-card card-surface">
                <span class="summary-label">Statements</span>
                <strong>@Document.Statements.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                <small>Current: #@SelectedStatement.StatementId</small>
            </div>
            <div class="summary-card summary-statement-card card-surface">
                <span class="summary-label">Selected statement</span>
                <strong>#@SelectedStatement.StatementId</strong>
                <small>@SelectedStatement.StatementType</small>
                @if (Document.Statements.Count > 1)
                {
                    <select class="form-select form-select-sm statement-select" value="@SelectedStatementId" @onchange="OnStatementChanged">
                        @foreach (var statement in Document.Statements)
                        {
                            <option value="@statement.StatementId">#@statement.StatementId - @statement.StatementType</option>
                        }
                    </select>
                }
            </div>
        </section>

        <section class="statement-text card-surface">
            <div class="section-header compact">
                <div>
                    <h2>Statement text</h2>
                </div>
            </div>
            <pre>@SelectedStatement.StatementText</pre>
        </section>

        <section class="summary-grid summary-grid-bottom">
            <div class="summary-card card-surface">
                <span class="summary-label">Operators</span>
                <strong>@SelectedStatement.Nodes.Count.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                <small>Total: @Document.TotalNodeCount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</small>
            </div>
            <div class="summary-card card-surface">
                <span class="summary-label">Warnings</span>
                <strong>@SelectedStatement.WarningCount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                <small>Total: @Document.TotalWarningCount.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</small>
            </div>
        </section>

        @if (combinedPlanDetailRows.Count > 0)
        {
            <section class="card-surface summary-table-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">Plan details</span>
                    </div>
                </div>
                <div class="summary-table-shell">
                    <table class="table table-sm align-middle summary-table plan-detail-table">
                        <thead>
                            <tr>
                                <th scope="col">Section</th>
                                <th scope="col">Property</th>
                                <th scope="col">Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in combinedPlanDetailRows)
                            {
                                <tr>
                                    @if (row.ShowSection)
                                    {
                                        <td class="object-cell section-cell" rowspan="@row.SectionRowSpan">@row.Section</td>
                                    }
                                    <td>@row.Name</td>
                                    <td class="details-cell">@row.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (accessedObjectItems.Count > 0)
        {
            <section class="card-surface summary-table-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">Accessed objects</span>
                    </div>
                </div>
                <div class="summary-table-shell">
                    <table class="table table-sm align-middle summary-table">
                        <thead>
                            <tr>
                                <th scope="col">Table</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in accessedObjectItems)
                            {
                                <tr>
                                    <td class="object-cell">@BuildAccessedObjectName(item)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (SelectedStatement.Summary.OptimizerStatsUsageEntries.Count > 0)
        {
            <section class="card-surface summary-table-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">OptimizerStatsUsage</span>
                    </div>
                </div>
                <div class="summary-table-shell">
                    <table class="table table-sm align-middle summary-table">
                        <thead>
                            <tr>
                                <th scope="col">Table</th>
                                <th scope="col">Statistics</th>
                                <th scope="col">Last update</th>
                                <th scope="col">Modification count</th>
                                <th scope="col">Last sample</th>
                                <th scope="col">Sampling %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in SelectedStatement.Summary.OptimizerStatsUsageEntries)
                            {
                                <tr>
                                    <td>@BuildOptimizerStatsUsageTableName(item)</td>
                                    <td>@FormatSummaryValue(item.Statistics)</td>
                                    <td>@FormatSummaryValue(item.LastUpdate)</td>
                                    <td class="numeric-cell">@FormatSummaryValue(item.StatisticsModificationCount)</td>
                                    <td>@FormatSummaryValue(item.LastSample)</td>
                                    <td class="numeric-cell">@FormatSummaryValue(item.SamplingPercent)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (missingIndexItems.Count > 0)
        {
            <section class="card-surface summary-table-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">MissingIndexes</span>
                    </div>
                </div>
                <div class="summary-table-shell">
                    <table class="table table-sm align-middle summary-table missing-index-table">
                        <thead>
                            <tr>
                                <th scope="col">Impact</th>
                                <th scope="col">Object</th>
                                <th scope="col">EQUALITY</th>
                                <th scope="col">INEQUALITY</th>
                                <th scope="col">INCLUDE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in missingIndexItems)
                            {
                                <tr>
                                    <td class="numeric-cell">@FormatSummaryValue(item.Impact)</td>
                                    <td class="object-cell">@item.ObjectName</td>
                                    <td class="details-cell">@FormatSummaryValue(item.EqualityColumns)</td>
                                    <td class="details-cell">@FormatSummaryValue(item.InequalityColumns)</td>
                                    <td class="details-cell">@FormatSummaryValue(item.IncludeColumns)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (SelectedStatement.Summary.WaitStatsEntries.Count > 0)
        {
            <section class="card-surface summary-table-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">WaitStats</span>
                    </div>
                </div>
                <div class="summary-table-shell">
                    <table class="table table-sm align-middle summary-table wait-stats-table">
                        <thead>
                            <tr>
                                <th scope="col">Wait type</th>
                                <th scope="col">WaitTimeMs</th>
                                <th scope="col">WaitCount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in SelectedStatement.Summary.WaitStatsEntries)
                            {
                                <tr>
                                    <td class="object-cell">@item.WaitType</td>
                                    <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.WaitTimeMs))</td>
                                    <td class="numeric-cell">@FormatSummaryValue(PlanDisplayFormatter.FormatNumber(item.WaitCount))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @if (warningRows.Count > 0)
        {
            <section class="card-surface summary-table-card warning-details-card">
                <div class="section-header compact">
                    <div>
                        <span class="summary-label">Warning details</span>
                    </div>
                </div>
                <div class="summary-table-shell warning-table-shell">
                    <table class="table table-sm align-middle summary-table warning-details-table">
                        <thead>
                            <tr>
                                <th scope="col" class="warning-node-col">Node</th>
                                <th scope="col">Operator</th>
                                <th scope="col">Warning</th>
                                <th scope="col">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in warningRows)
                            {
                                <tr class="@(string.Equals(row.NodeId, SelectedNodeId, StringComparison.Ordinal) ? "selected-warning-row" : null)">
                                    <td class="warning-node-cell">
                                        @if (row.NodeId is null)
                                        {
                                            <span class="warning-statement-label">Statement</span>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="warning-node-button"
                                                    @onclick="@(() => HandleGraphNodeSelected(row.NodeId!))">
                                                Node @row.NodeId
                                            </button>
                                        }
                                    </td>
                                    <td class="warning-operator-cell">@row.Operator</td>
                                    <td class="warning-name-cell">@row.Warning</td>
                                    <td class="warning-details-cell">@row.Details</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        <div class="viewer-grid @(SelectedStatement is not null ? "with-details" : null)">
            <div class="viewer-main">
                <section class="card-surface">
                    <div class="section-header">
                        <div>
                            <h2>Graphical plan</h2>
                        </div>
                        <div class="graph-header-actions">
                            <div class="section-chips">
                                <span class="chip">@SelectedStatement!.Nodes.Count operators</span>
                                <span class="chip">@SelectedStatement.Edges.Count edges</span>
                            </div>
                            <label class="graph-threshold-setting">
                                <span class="graph-threshold-label">Dashed outline &gt; cost</span>
                                <div class="input-group input-group-sm graph-threshold-input">
                                    <input type="number"
                                           class="form-control"
                                           min="0"
                                           max="100"
                                           step="1"
                                           @bind="GraphCostThresholdPercent" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </label>
                            <label class="graph-threshold-setting graph-critical-toggle">
                                <input type="checkbox" class="form-check-input" @bind="ShowCriticalPath" />
                                <span class="graph-threshold-label">Critical path (est. cost)</span>
                            </label>
                        </div>
                    </div>

                    <PlanGraphView @key="ActivePlanId"
                                   Layout="SelectedLayout"
                                   CostHighlightThresholdPercent="GraphCostThresholdPercent"
                                   ShowCriticalPath="ShowCriticalPath"
                                   SelectedNodeId="@SelectedNodeId"
                                   SelectedStatementId="@SelectedStatementDetailId"
                                   ExportBaseName="@BuildExportBaseName()"
                                   OnSelectNode="HandleGraphNodeSelected"
                                   OnSelectStatement="HandleGraphStatementSelected"
                                   OnHoverNode="HandleNodeHovered" />
                </section>

                <section class="card-surface">
                    <div class="section-header">
                        <div>
                            <h2>Table view</h2>
                        </div>
                        <div class="table-header-actions">
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DownloadTableCsv" disabled="@(CurrentRows.Count == 0)">Download CSV</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DownloadTableMarkdown" disabled="@(CurrentRows.Count == 0)">Download Markdown</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DownloadTableJson" disabled="@(CurrentRows.Count == 0)">Download JSON</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CopyTableCsv" disabled="@(CurrentRows.Count == 0)">Copy</button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(TableActionMessage))
                    {
                        <p class="table-action-message" aria-live="polite">@TableActionMessage</p>
                    }

                    <PlanNodeTable @key="ActivePlanId"
                                   Rows="CurrentRows"
                                   SelectedNodeId="@SelectedNodeId"
                                   FocusRequestVersion="TableFocusRequestVersion"
                                   OnSelectNode="HandleTableNodeSelected"
                                   OnHoverNode="HandleNodeHovered" />
                </section>

                <section class="card-surface diagnostics-card">
                    <div class="section-header compact">
                        <div>
                            <span class="summary-label">Diagnostics</span>
                        </div>
                    </div>
                    <PlanDiagnosticsPanel Diagnostics="statementDiagnostics" OnSelectNode="HandleGraphNodeSelected" />
                </section>
            </div>
            @if (SelectedStatement is not null)
            {
                var showStatementDetails = IsStatementDetailsSelected && OverlayNode is null;
                var showDetails = OverlayNode is not null || showStatementDetails;
                <aside class="details-column">
                    <section class="card-surface sticky-panel operator-pane" aria-live="polite" @ref="detailsPaneRef">
                        <div class="details-resizer"
                             @ref="detailsResizeHandleRef"
                             role="separator"
                             aria-label="Resize operator details panel"
                             aria-orientation="vertical"></div>
                        <div class="section-header compact">
                            <div>
                                <div class="eyebrow">Operator details</div>
                                <h2>@(OverlayNode?.PhysicalOp ?? (showStatementDetails ? $"{SelectedStatement.StatementType} statement" : "No operator selected"))</h2>
                            </div>
                            <div class="details-header-actions">
                                @if (showDetails)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CloseOverlay">Close</button>
                                }
                            </div>
                        </div>

                        @if (OverlayNode is not null)
                        {
                            <PlanNodeDetails Statement="SelectedStatement" Node="OverlayNode" />
                        }
                        else if (showStatementDetails)
                        {
                            <PlanNodeDetails Statement="SelectedStatement" />
                        }
                    </section>
                </aside>
            }
        </div>
    }
</div>
